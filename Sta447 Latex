\subsection{Lecture 5: Martingales and stopping times}

\begin{definition}[Martingale, supermartingale, submartingale]
Let $(\mathcal F_n)_{n\ge 0}$ be a filtration. An integrable adapted process $(M_n)_{n\ge 0}$ is a martingale if
\[
\mathbb E[M_{n+1}\mid \mathcal F_n]=M_n
\qquad \text{a.s. for all } n\ge 0.
\]
It is a supermartingale if
\[
\mathbb E[M_{n+1}\mid \mathcal F_n]\le M_n,
\]
and a submartingale if
\[
\mathbb E[M_{n+1}\mid \mathcal F_n]\ge M_n.
\]
\end{definition}

\begin{definition}[Stopping time]
A random time $T:\Omega\to\{0,1,2,\dots,\infty\}$ is a stopping time with respect to $(\mathcal F_n)$ if for every $n\ge 0$,
\[
\{T\le n\}\in \mathcal F_n.
\]
\end{definition}

\begin{theorem}[Bounded optional stopping theorem]
Let $(M_n)_{n\ge 0}$ be a martingale and let $T$ be a bounded stopping time. Then
\[
\mathbb E[M_T]=\mathbb E[M_0].
\]
More generally, if $S\le T$ are bounded stopping times, then
\[
\mathbb E[M_T\mid \mathcal F_S]=M_S
\qquad \text{a.s.}
\]
\end{theorem}

\begin{theorem}[Optional stopping under integrability assumptions]
Let $(M_n)$ be a martingale and $T$ a stopping time. If one of the standard hypotheses ensuring passage to the limit holds---for example, $T$ is bounded, or $(M_{n\wedge T})$ is uniformly integrable, or the stopped process is dominated by an integrable random variable---then
\[
\mathbb E[M_T]=\mathbb E[M_0].
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item checking whether a process is a martingale by conditional expectation;
    \item proving a random time is or is not a stopping time;
    \item applying optional stopping to gambler's ruin and first-hitting problems.
\end{itemize}

\subsection{Lecture 6: Uniform integrability, Wald, maximal inequalities}

\begin{definition}[Uniform integrability]
A family of integrable random variables $\mathcal X$ is uniformly integrable if
\[
\lim_{K\to\infty}\sup_{X\in\mathcal X}\mathbb E\bigl[|X|\mathbf 1_{\{|X|>K\}}\bigr]=0.
\]
A sequence $(X_n)$ is uniformly integrable if the family $\{X_n:n\ge 0\}$ is uniformly integrable.
\end{definition}

\begin{proposition}[A sufficient condition for UI]
If there exists an integrable random variable $Y$ such that
\[
|X_n|\le Y \qquad \text{a.s. for all } n,
\]
then $(X_n)$ is uniformly integrable.
\end{proposition}

\begin{theorem}[Wald's identity]
Let $(\xi_k)_{k\ge 1}$ be i.i.d. integrable random variables with $\mathbb E[\xi_1]=m$, and let $T$ be a stopping time such that the hypotheses of optional stopping apply to the martingale
\[
M_n:=\sum_{k=1}^n \xi_k - nm.
\]
Then
\[
\mathbb E\Bigl[\sum_{k=1}^{T}\xi_k\Bigr]=m\,\mathbb E[T].
\]
\end{theorem}

\begin{theorem}[Doob's maximal inequality: nonnegative case]
If $(M_n)_{n\ge 0}$ is a nonnegative submartingale, then for every $\lambda>0$ and every $n$,
\[
\lambda\,\mathbb P\Bigl(\max_{0\le k\le n} M_k\ge \lambda\Bigr)
\le \mathbb E[M_n].
\]
\end{theorem}

\begin{theorem}[$L^2$ martingale convergence]
If $(M_n)_{n\ge 0}$ is a martingale and
\[
\sup_{n\ge 0}\mathbb E[M_n^2]<\infty,
\]
then there exists a random variable $M_\infty\in L^2$ such that
\[
M_n\to M_\infty \quad \text{a.s. and in } L^2.
\]
In particular,
\[
M_n=\mathbb E[M_\infty\mid \mathcal F_n].
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item checking UI or failure of UI;
    \item stopped martingales and bounded stopped processes;
    \item geometric-type stopping times and Wald's identity;
    \item tail bounds from Doob's inequality.
\end{itemize}

\subsection{Lecture 7: Martingale convergence and UI}

\begin{theorem}[Martingale convergence theorem: nonnegative / one-sided bounded case]
If $(M_n)_{n\ge 0}$ is a nonnegative supermartingale, then there exists an integrable random variable $M_\infty$ such that
\[
M_n\to M_\infty \qquad \text{a.s.}
\]
The same conclusion holds for a martingale that is bounded below by an integrable random variable.
\end{theorem}

\begin{theorem}[Up-crossing inequality]
Let $(X_n)$ be a submartingale and let $a<b$. Denote by $U_n[a,b]$ the number of completed up-crossings of the interval $[a,b]$ by time $n$. Then
\[
(b-a)\,\mathbb E[U_n[a,b]]
\le
\mathbb E[(X_n-a)^+] - \mathbb E[(X_0-a)^+].
\]
\end{theorem}

\begin{theorem}[Uniform integrability and $L^1$ convergence]
Let $(M_n)_{n\ge 0}$ be a martingale. The following are equivalent:
\begin{enumerate}[label=(\roman*)]
    \item $(M_n)$ is uniformly integrable;
    \item there exists an integrable random variable $M_\infty$ such that
    \[
    M_n\to M_\infty \quad \text{in } L^1;
    \]
    \item there exists an integrable random variable $M_\infty$ such that for every $n$,
    \[
    M_n=\mathbb E[M_\infty\mid \mathcal F_n].
    \]
\end{enumerate}
In this case,
\[
\mathbb E[M_\infty]=\mathbb E[M_0].
\]
\end{theorem}

\begin{theorem}[Doob's $L^p$ maximal inequality]
If $(M_n)_{n\ge 0}$ is a martingale and $p>1$, then
\[
\Bigl\|\max_{0\le k\le n}|M_k|\Bigr\|_p
\le \frac{p}{p-1}\,\|M_n\|_p.
\]
\end{theorem}

\begin{theorem}[Optional stopping for UI martingales]
Let $(M_n)$ be a uniformly integrable martingale and let $T$ be a stopping time. If $M_T$ is integrable, then
\[
\mathbb E[M_T]=\mathbb E[M_0].
\]
If $S\le T$ are stopping times and the relevant conditional expectations are integrable, then
\[
\mathbb E[M_T\mid \mathcal F_S]=M_S
\qquad \text{a.s.}
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item proving almost sure convergence from lower bounds or nonnegativity;
    \item giving counterexamples where a.s. convergence does not imply $L^1$ convergence;
    \item using UI to justify optional stopping at unbounded times.
\end{itemize}

