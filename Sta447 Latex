\]

\paragraph{(1) Compute $\mathbb E[T_1\mid X_0=1]$.}
\textbf{Answer:}
\[
\mathbb E_1[T_1]=5.
\]

\textbf{Explanation.} By symmetry, the stationary distribution is uniform:
\[
\pi_i=\frac15, \qquad i=1,2,3,4,5.
\]
The chain is irreducible, so the recurrence time theorem applies:
\[
\mathbb E_1[T_1]=\frac{1}{\pi_1}=5.
\]

\paragraph{(2) Compute $\mathbb P(T_5<T_2\mid X_0=1)$.}
\textbf{Answer:}
\[
\mathbb P(T_5<T_2\mid X_0=1)=\frac37.
\]

\textbf{Explanation.} Let
\[
q_i:=\mathbb P_i(T_5<T_2).
\]
Then $q_2=0$ and $q_5=1$. Starting from $1$, the first step goes to $2$ or $3$ with probability $1/2$ each, so
\[
q_1=\frac12\cdot 0 + \frac12 q_3.
\]
From $3$,
\[
q_3=\frac12 q_4 + \frac12\cdot 1.
\]
From $4$,
\[
q_4=\frac12 q_1 + \frac12\cdot 1.
\]
Substitute the last two equations into the first:
\[
q_1=\frac12\left(\frac12 q_4 + \frac12\right)
=\frac14 q_4 + \frac14
=\frac14\left(\frac12 q_1+\frac12\right)+\frac14.
\]
Hence
\[
q_1=\frac18 q_1 + \frac38,
\qquad
\frac78 q_1=\frac38,
\qquad
q_1=\frac37.
\]

\subsection*{Question 3 \hfill [13 points]}
Consider the Markov chain on $S=\{0,1,2,\dots\}$ with transitions
\[
 p_{i,i+1}=q,
 \qquad
 p_{i,i-1}=1-q
 \quad (i\ge 1),
\]
and
\[
 p_{0,0}=\frac12,
 \qquad
 p_{0,1}=\frac12,
\]
where $q\in(0,1)$.

\paragraph{(1) Find a stationary measure.}
\textbf{Answer:} One stationary measure is given by
\[
\mu_0=2(1-q),
\qquad
\mu_i=\left(\frac{q}{1-q}\right)^{i-1}, \quad i\ge 1.
\]

\textbf{Explanation.} For a birth--death chain, use detailed balance:
\[
\mu_i q = \mu_{i+1}(1-q), \qquad i\ge 1.
\]
So
\[
\mu_{i+1}=\mu_i\frac{q}{1-q},
\qquad
\mu_i=\mu_1\left(\frac{q}{1-q}\right)^{i-1}.
\]
At $0$,
\[
\mu_0\cdot \frac12 = \mu_1(1-q),
\]
so if we choose $\mu_1=1$, then
\[
\mu_0=2(1-q).
\]
Any positive scalar multiple is also a stationary measure.

\paragraph{(2) Classify the chain as positive recurrent, null recurrent, or transient.}
\textbf{Answer:}
\begin{itemize}[leftmargin=2em]
    \item positive recurrent if $q<\frac12$;
    \item null recurrent if $q=\frac12$;
    \item transient if $q>\frac12$.
\end{itemize}

\textbf{Explanation.} If $q<1/2$, then
\[
\frac{q}{1-q}<1,
\]
so the stationary measure has finite total mass and can be normalized to a stationary distribution. Hence the chain is positive recurrent.

If $q=1/2$, the chain behaves like simple symmetric random walk on $\mathbb Z_+$ with reflection at $0$. This is recurrent, but the stationary measure has infinite mass, so it is null recurrent.

If $q>1/2$, the chain has positive drift to the right. Using the gambler's ruin formula for
\[
 p_{i,N}:=\mathbb P_i(T_0>T_N),
\]
and letting $N\to\infty$, one gets
\[
\mathbb P_i(\text{never hit }0)=1-\left(\frac{1-q}{q}\right)^i>0.
\]
So the chain is transient.

\subsection*{Question 4 \hfill [28 points]}
Let $(B_t)_{t\ge 0}$ be standard Brownian motion.

\paragraph{(1) Compute}
\[
\lim_{N\to\infty}\sum_{i=0}^{N-1} B_{(i+1)/N}\Bigl(B_{(i+1)/N}-B_{i/N}\Bigr).
\]

\textbf{Answer:}
\[
\frac12 B_1^2+\frac12.
\]

\textbf{Explanation.} Split the right-endpoint term into a left-endpoint term plus a quadratic-variation term:
\[
B_{(i+1)/N}\bigl(B_{(i+1)/N}-B_{i/N}\bigr)
=
B_{i/N}\bigl(B_{(i+1)/N}-B_{i/N}\bigr)
+
\bigl(B_{(i+1)/N}-B_{i/N}\bigr)^2.
\]
Summing and taking limits gives
\[
\int_0^1 B_t\,dB_t + \langle B\rangle_1.
\]
Now
\[
\int_0^1 B_t\,dB_t = \frac12 B_1^2 - \frac12
\]
by It\^o's formula, and
\[
\langle B\rangle_1=1.
\]
Therefore the limit is
\[
\frac12 B_1^2 - \frac12 + 1 = \frac12 B_1^2+\frac12.
\]

\paragraph{(2) Suppose $dX_t=f(X_t)\,dB_t$ and}
\[
M_t:=e^{X_t}-\int_0^t h(X_s)\,ds
\]
is a martingale. Find $h$ and write $M_t-M_0$ as an It\^o integral.

\textbf{Answer:}
\[
 h(x)=\frac12 e^x f(x)^2,
 \qquad
 M_t-M_0=\int_0^t e^{X_s}f(X_s)\,dB_s.
\]

\textbf{Explanation.} Apply It\^o's formula to $e^{X_t}$:
\[
 d(e^{X_t}) = e^{X_t}\,dX_t + \frac12 e^{X_t}\,d\langle X\rangle_t.
\]
Since
\[
 dX_t=f(X_t)\,dB_t,
 \qquad
 d\langle X\rangle_t=f(X_t)^2\,dt,
\]
we get
\[
 d(e^{X_t}) = e^{X_t}f(X_t)\,dB_t + \frac12 e^{X_t}f(X_t)^2\,dt.
\]
So the drift term is exactly
\[
 h(x)=\frac12 e^x f(x)^2,
\]
and subtracting it leaves the It\^o integral.

\paragraph{(3) Let $M:=\max_{0\le t\le 1} B_t$. Compute}
\[
\mathbb E\bigl[B_1\mathbf 1_{\{M\ge a\}}\bigr].
\]

\textbf{Answer:}
\[
\mathbb E\bigl[B_1\mathbf 1_{\{M\ge a\}}\bigr]
=
2a\,\mathbb P(B_1\ge a)
=
\frac{2a}{\sqrt{2\pi}}\int_a^{\infty} e^{-x^2/2}\,dx.
\]

\textbf{Explanation.} Let
\[
T:=\inf\{t\ge 0: B_t\ge a\}.
\]
Then
\[
\{M\ge a\}=\{T\le 1\}.
\]
By the strong Markov property, conditional on $T\le 1$ and the path up to time $T$, the increment $B_1-B_T$ has mean $0$. Since $B_T=a$,
\[
\mathbb E[B_1\mid T\le 1]=a.
\]
Therefore
\[
\mathbb E[B_1\mathbf 1_{\{M\ge a\}}]
=
\mathbb P(T\le 1)\,a.
\]
By the reflection principle,
\[
\mathbb P(T\le 1)=2\mathbb P(B_1\ge a),
\]
which gives the result.

\paragraph{(4) Suppose $X_0=0$ and}
\[
 dX_t=\frac{1}{X_t+1}\,dt + dB_t,
\]
and $X_t>-1$ always. Show that
\[
M_t=(X_t+1)^2-3t
\]
is a martingale, and compute
\[
\mathbb E[\tau],
\qquad
\tau:=\inf\{t>0:X_t\ge 2\}.
\]

\textbf{Answer:}
\[
M_t\text{ is a martingale,}
\qquad
\mathbb E[\tau]=\frac83.
\]

\textbf{Explanation.} Apply It\^o's formula to $f(x)=(x+1)^2$:
\[
 d\bigl((X_t+1)^2\bigr)=2(X_t+1)\,dX_t + d\langle X\rangle_t.
\]
Since $d\langle X\rangle_t=dt$ and
\[
 dX_t=\frac{1}{X_t+1}\,dt+dB_t,
\]
we obtain
\[
 d\bigl((X_t+1)^2\bigr)=2dt + 2(X_t+1)\,dB_t + dt = 3dt + 2(X_t+1)\,dB_t.
\]
Hence
\[
 dM_t = 2(X_t+1)\,dB_t,
\]
so $M_t$ is a martingale.

At the stopping time $\tau$, we have $X_{\tau}=2$, so
\[
 M_{\tau}=9-3\tau.
\]
Under the integrability condition justified in the official solution, optional stopping gives
\[
 M_0=\mathbb E[M_{\tau}].
\]
Because $X_0=0$,
\[
 M_0=(0+1)^2=1.
\]
Thus
\[
 1 = 9-3\mathbb E[\tau],
\qquad
 \mathbb E[\tau]=\frac83.
\]

\subsection*{Question 5 \hfill [8 points]}
Let $(N(t))_{t\ge 0}$ be a Poisson process with intensity $\lambda>0$. Let
\[
0<T_1<T_2<\cdots<T_{N(t)}\le t
\]
be the arrival times in $[0,t]$. Compute
\[
\mathbb E\left[\exp\left(-\sum_{i=1}^{N(t)} T_i\right)\right].
\]

\textbf{Answer:}
\[
\exp\bigl(\lambda(1-t-e^{-t})\bigr).
\]

\textbf{Explanation.} Condition on $N(t)=n$. Given $N(t)=n$, the arrival times are i.i.d. uniform on $[0,t]$. Therefore
\[
\mathbb E\left[\exp\left(-\sum_{i=1}^{N(t)} T_i\right)\middle|N(t)=n\right]
=
\left(\mathbb E[e^{-T}]\right)^n,
\]
where $T\sim \mathrm{Unif}[0,t]$. Now
\[
\mathbb E[e^{-T}] = \frac1t\int_0^t e^{-s}\,ds = \frac{1-e^{-t}}{t}.
\]
Hence
\[
\mathbb E\left[\exp\left(-\sum_{i=1}^{N(t)} T_i\right)\right]
=
\sum_{n=0}^{\infty}
\left(\frac{1-e^{-t}}{t}\right)^n
 e^{-\lambda t}\frac{(\lambda t)^n}{n!}.
\]
Recognizing the exponential series,
\[
= e^{-\lambda t}\exp\bigl(\lambda(1-e^{-t})\bigr)
= \exp\bigl(\lambda(1-t-e^{-t})\bigr).
\]

\subsection*{Question 6 \hfill [17 points]}
Let $\mu$ be a probability distribution on $[0,1)$. Define intervals recursively by halving and choosing left/right with probability $1/2$, and set
\[
X_n := 2^n\,\mathbb P_{Z\sim\mu}(a_n\le Z<b_n).
\]

\paragraph{(1) Show there exists $X_\infty$ such that $X_n\to X_\infty$ almost surely.}

\textbf{Answer:} Such an $X_\infty$ exists almost surely.

\textbf{Explanation.} Let $\mathcal F_n$ be the information generated by the first $n$ interval choices. Then
\[
\mathbb E[X_{n+1}\mid \mathcal F_n]
=
\frac12\cdot 2^{n+1}\,\mu\!\left([a_n,\tfrac{a_n+b_n}{2})\right)
+
\frac12\cdot 2^{n+1}\,\mu\!\left([\tfrac{a_n+b_n}{2},b_n)\right)
= X_n.
\]
So $(X_n)$ is a martingale. Also $X_n\ge 0$, hence by the nonnegative martingale convergence theorem,
\[
X_n\to X_\infty \qquad \text{a.s.}
\]
for some random variable $X_\infty$.

\paragraph{(2) Construct $\mu$ such that the convergence is not in $L^1$.}

\textbf{Answer:} Take
\[
\mu=\delta_{1/2}.
\]

\textbf{Explanation.} If all mass is concentrated at $1/2$, then on most interval choices the selected interval eventually misses $1/2$, so $X_n=0$ there. In fact,
\[
X_n\to 0 \qquad \text{a.s.}
\]
but
\[
\mathbb E[X_n]=\mathbb E[X_0]=1
\qquad \text{for all } n.
\]
Therefore $X_n$ cannot converge to $0$ in $L^1$.

\paragraph{(3) Suppose $\mu$ has density $p_\mu$ on $[0,1]$. Find $X_\infty$ and prove $L^1$ convergence.}

\textbf{Answer:}
\[
X_\infty = p_\mu(U),
\qquad
U\sim \mathrm{Unif}[0,1].
\]
Moreover,
\[
X_n\to X_\infty \qquad \text{in }L^1.
\]

\textbf{Explanation.} The nested dyadic intervals $[a_n,b_n)$ shrink to a random point $U$ that is uniform on $[0,1]$. Also,
\[
X_n = \frac{1}{b_n-a_n}\int_{a_n}^{b_n} p_\mu(z)\,dz.
\]
So $X_n$ is the average value of the density over a shrinking interval around $U$, and the limit is
\[
X_\infty=p_\mu(U).
\]
A very useful representation is
\[
X_n=\mathbb E[p_\mu(U)\mid \mathcal F_n],
\]
so $(X_n)$ is a Doob martingale. Since the terminal random variable $p_\mu(U)$ is integrable, the Doob martingale is uniformly integrable, and thus
\[
X_n\to X_\infty
\qquad \text{in }L^1.
\]

