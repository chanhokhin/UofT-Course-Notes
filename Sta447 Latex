\subsection{Lecture 1: Discrete-time Markov chains}

\begin{definition}[Discrete-time Markov chain]
Let $S$ be a finite or countable state space. A stochastic process $(X_n)_{n\ge 0}$ taking values in $S$ is a discrete-time Markov chain if there is an initial distribution $\nu$ and a transition matrix $P=(p_{ij})_{i,j\in S}$ such that for all $n\ge 0$ and all states $x_0,\dots,x_n,j\in S$,
\[
\mathbb P(X_{n+1}=j\mid X_0=x_0,\dots,X_n=x_n)
=
\mathbb P(X_{n+1}=j\mid X_n=x_n)
=
p_{x_nj}.
\]
\end{definition}

\begin{definition}[$n$-step transition probabilities]
For $n\ge 0$, define
\[
p_{ij}^{(n)}:=\mathbb P(X_n=j\mid X_0=i),
\qquad P^{(n)}=(p_{ij}^{(n)})_{i,j\in S}.
\]
In particular, $P^{(1)}=P$ and $P^{(0)}=I$.
\end{definition}

\begin{theorem}[Chapman--Kolmogorov equation]
For all $m,n\ge 0$ and $i,j\in S$,
\[
p_{ij}^{(m+n)}=\sum_{k\in S} p_{ik}^{(m)}p_{kj}^{(n)}.
\]
Equivalently,
\[
P^{(m+n)}=P^{(m)}P^{(n)}.
\]
\end{theorem}

\begin{definition}[Accessibility, communication, irreducibility]
For states $i,j\in S$:
\begin{itemize}[leftmargin=2em]
    \item we write $i\to j$ if there exists $n\ge 0$ such that $p_{ij}^{(n)}>0$;
    \item we write $i\leftrightarrow j$ if $i\to j$ and $j\to i$;
    \item the chain is called \emph{irreducible} if $i\leftrightarrow j$ for every $i,j\in S$.
\end{itemize}
\end{definition}

\begin{definition}[Stationary distribution]
A probability distribution $\pi=(\pi_i)_{i\in S}$ on $S$ is called stationary if
\[
\pi P=\pi,
\]
that is,
\[
\pi_j=\sum_{i\in S}\pi_i p_{ij}
\qquad \text{for every } j\in S.
\]
\end{definition}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item random walk on a circle;
    \item computing multi-step probabilities using $P^n$;
    \item checking whether states communicate;
    \item checking whether a probability vector is stationary.
\end{itemize}

\subsection{Lecture 2: Recurrence criterion and first-step methods}

\begin{definition}[Return probability and recurrence]
For a state $i\in S$, define
\[
T_i^+:=\inf\{n\ge 1:X_n=i\}
\]
and
\[
f_{ii}:=\mathbb P_i(T_i^+<\infty).
\]
The state $i$ is called \emph{recurrent} if $f_{ii}=1$, and \emph{transient} if $f_{ii}<1$.
\end{definition}

\begin{theorem}[Recurrence criterion]
For any state $i\in S$,
\[
i \text{ is recurrent}
\iff
\sum_{n=1}^{\infty} p_{ii}^{(n)}=\infty.
\]
Equivalently,
\[
i \text{ is transient}
\iff
\sum_{n=1}^{\infty} p_{ii}^{(n)}<\infty.
\]
\end{theorem}

\begin{proposition}[Expected number of visits]
Let
\[
N(j):=\sum_{n=0}^{\infty}\mathbf 1_{\{X_n=j\}}
\]
be the total number of visits to the state $j$. Then for any $i,j\in S$,
\[
\mathbb E_i[N(j)] = \sum_{n=0}^{\infty} p_{ij}^{(n)}.
\]
If $j$ is transient, then
\[
\mathbb E_i[N(j)] = \frac{f_{ij}}{1-f_{jj}}.
\]
\end{proposition}

\begin{proposition}[First-step expansion for hitting probabilities]
Fix a state $j\in S$ and define
\[
f_{ij}:=\mathbb P_i(T_j<\infty),
\qquad T_j:=\inf\{n\ge 0:X_n=j\}.
\]
Then
\[
f_{jj}=1,
\]
and for $i\neq j$,
\[
f_{ij}=\sum_{k\in S} p_{ik}f_{kj}
= p_{ij}+\sum_{k\neq j} p_{ik}f_{kj}.
\]
\end{proposition}

\begin{proposition}[First-step expansion for expected hitting times]
Fix a state $j\in S$ and define
\[
g_i:=\mathbb E_i[T_j].
\]
Then
\[
g_j=0,
\]
and for $i\neq j$,
\[
g_i = 1 + \sum_{k\in S} p_{ik}g_k.
\]
\end{proposition}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item computing $f_{ij}$ by conditioning on the first step;
    \item expected number of visits via
    \[
    \mathbb E_i[N(j)] = \frac{f_{ij}}{1-f_{jj}}
    \quad\text{when } j\text{ is transient};
    \]
    \item gambler's ruin style boundary-value equations;
    \item recurrence/transience of simple random walk examples.
\end{itemize}

\subsection{Lecture 3: Irreducible chains}

\begin{theorem}[Class property of recurrence / transience]
If $i\leftrightarrow j$, then $i$ is recurrent if and only if $j$ is recurrent. Equivalently, if $i\leftrightarrow j$, then $i$ is transient if and only if $j$ is transient.
\end{theorem}

\begin{theorem}[Equivalent forms of recurrence]
For any state $j\in S$, the following are equivalent:
\begin{enumerate}[label=(\roman*)]
    \item $j$ is recurrent;
    \item $\sum_{n=1}^{\infty} p_{jj}^{(n)}=\infty$;
    \item $\mathbb P_j(N(j)=\infty)=1$.
\end{enumerate}
\end{theorem}

\begin{theorem}[Equivalent forms of transience]
For any state $j\in S$, the following are equivalent:
\begin{enumerate}[label=(\roman*)]
    \item $j$ is transient;
    \item $\sum_{n=1}^{\infty} p_{jj}^{(n)}<\infty$;
    \item $\mathbb P_j(N(j)<\infty)=1$;
    \item $\mathbb E_j[N(j)]<\infty$.
\end{enumerate}
\end{theorem}

\begin{proposition}[Expected visits in an irreducible chain]
If an irreducible chain is recurrent, then for every pair of states $i,j$,
\[
\sum_{n=0}^{\infty} p_{ij}^{(n)}=\infty.
\]
If it is transient, then for every pair of states $i,j$,
\[
\sum_{n=0}^{\infty} p_{ij}^{(n)}<\infty.
\]
\end{proposition}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item biased random walk on $\mathbb Z$ as an irreducible but transient chain;
    \item using communication to move recurrence information between states;
    \item deciding whether statements involving $f_{ij}=1$ are true or false.
\end{itemize}

\subsection{Lecture 4: Stationarity and convergence}

\begin{definition}[Stationary measure]
A nonnegative function $\mu=(\mu_i)_{i\in S}$ is called a stationary measure if
\[
\mu P = \mu.
\]
Unlike a stationary distribution, we do not require $\sum_i \mu_i=1$.
\end{definition}

\begin{proposition}[Detailed balance implies stationarity]
Suppose $\pi$ is a probability distribution on $S$ satisfying
\[
\pi_i p_{ij}=\pi_j p_{ji}
\qquad \text{for all } i,j\in S.
\]
Then $\pi$ is a stationary distribution.
\end{proposition}

\begin{theorem}[Finite irreducible chains are positive recurrent]
Every irreducible Markov chain on a finite state space has a unique stationary distribution, and every state is positive recurrent.
\end{theorem}

\begin{theorem}[Markov chain convergence theorem]
If a discrete-time Markov chain is irreducible, aperiodic, and positive recurrent with stationary distribution $\pi$, then for every $i,j\in S$,
\[
\lim_{n\to\infty} p_{ij}^{(n)} = \pi_j.
\]
\end{theorem}

\begin{theorem}[Recurrence time theorem]
Let $P$ be irreducible and positive recurrent with stationary distribution $\pi$. Then for every state $i$,
\[
\mathbb E_i[T_i^+] = \frac{1}{\pi_i}.
\]
More generally, for every pair $i,j$ in an irreducible positive recurrent chain,
\[
\mathbb E_i[T_j] < \infty.
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item building stationary distributions by symmetry;
    \item building stationary distributions by detailed balance;
    \item classifying all stationary distributions in reducible finite chains;
    \item proving convergence by checking irreducible/aperiodic/positive recurrent.
\end{itemize}

