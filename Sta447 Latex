\subsection{Lecture 8: Brownian motion and It\^o integral}

\begin{definition}[Standard Brownian motion]
A process $(B_t)_{t\ge 0}$ is a standard Brownian motion if:
\begin{enumerate}[label=(\roman*)]
    \item $B_0=0$ almost surely;
    \item $(B_t)_{t\ge 0}$ has continuous sample paths almost surely;
    \item for $0\le s<t$, the increment $B_t-B_s$ is Gaussian with mean $0$ and variance $t-s$;
    \item increments over disjoint time intervals are independent.
\end{enumerate}
\end{definition}

\begin{theorem}[Brownian motion is a martingale]
With respect to its natural filtration $(\mathcal F_t^B)$, Brownian motion satisfies
\[
\mathbb E[B_t\mid \mathcal F_s^B]=B_s
\qquad \text{for all } 0\le s\le t.
\]
Thus $(B_t)_{t\ge 0}$ is a martingale.
\end{theorem}

\begin{theorem}[Markov and strong Markov properties of Brownian motion]
Brownian motion is a Markov process: for $0\le s<t$,
\[
\mathbb P(B_t\in A\mid \mathcal F_s^B)=\mathbb P(B_t\in A\mid B_s)
\qquad \text{a.s.}
\]
Moreover, if $T$ is a stopping time, then the shifted process
\[
(B_{T+t}-B_T)_{t\ge 0}
\]
is independent of $\mathcal F_T$ and is again a standard Brownian motion.
\end{theorem}

\begin{definition}[Continuous-time stopping time]
A random time $T:\Omega\to[0,\infty]$ is a stopping time with respect to a filtration $(\mathcal F_t)_{t\ge 0}$ if
\[
\{T\le t\}\in \mathcal F_t
\qquad \text{for every } t\ge 0.
\]
\end{definition}

\begin{theorem}[Reflection principle]
For standard Brownian motion and $a>0$,
\[
\mathbb P\Bigl(\max_{0\le s\le t} B_s \ge a\Bigr)
=2\mathbb P(B_t\ge a).
\]
Equivalently,
\[
\mathbb P\Bigl(\max_{0\le s\le t} B_s < a\Bigr)
=1-2\mathbb P(B_t\ge a).
\]
A more general reflected-path identity also gives joint laws involving $\max_{s\le t}B_s$ and $B_t$.
\end{theorem}

\begin{definition}[It\^o integral]
Let $(Y_t)_{t\ge 0}$ be an adapted process satisfying
\[
\mathbb E\Bigl[\int_0^T Y_t^2\,dt\Bigr]<\infty.
\]
The It\^o integral
\[
\int_0^T Y_t\,dB_t
\]
is defined as the $L^2$-limit of left-endpoint stochastic sums for adapted simple approximations to $Y$.
\end{definition}

\begin{theorem}[Basic properties of the It\^o integral]
If $(Y_t)$ is adapted and square-integrable on $[0,T]$, then
\[
M_t:=\int_0^t Y_s\,dB_s
\]
is a martingale. Moreover,
\[
\mathbb E\Bigl[\int_0^T Y_t\,dB_t\Bigr]=0
\]
and the It\^o isometry holds:
\[
\mathbb E\Bigl[\Bigl(\int_0^T Y_t\,dB_t\Bigr)^2\Bigr]
=
\mathbb E\Bigl[\int_0^T Y_t^2\,dt\Bigr].
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item Brownian gambler's ruin;
    \item reflection-principle computations involving $\max_{t\le 1} B_t$;
    \item showing processes of the form $\int_0^t Y_s\,dB_s$ are martingales;
    \item turning Riemann sums into It\^o integrals or ordinary time integrals.
\end{itemize}

\subsection{Lecture 9: It\^o's formula and quadratic variation}

\begin{theorem}[It\^o's formula for $f(B_t)$]
Suppose $f\in C^2(\mathbb R)$. Then for every $T\ge 0$,
\[
f(B_T)-f(B_0)
=
\int_0^T f'(B_t)\,dB_t
+
\frac12\int_0^T f''(B_t)\,dt.
\]
Equivalently,
\[
df(B_t)=f'(B_t)\,dB_t+\frac12 f''(B_t)\,dt.
\]
\end{theorem}

\begin{definition}[One-dimensional It\^o process]
A process $(Z_t)_{t\ge 0}$ is called an It\^o process if it has the form
\[
dZ_t = X_t\,dt + Y_t\,dB_t,
\]
that is,
\[
Z_t = Z_0 + \int_0^t X_s\,ds + \int_0^t Y_s\,dB_s
\]
for adapted processes $(X_t)$ and $(Y_t)$.
\end{definition}

\begin{definition}[Quadratic variation]
Given a process $(Z_t)_{t\ge 0}$, its quadratic variation, when it exists, is
\[
\langle Z\rangle_t
=
\lim_{N\to\infty}
\sum_{i=0}^{N-1}(Z_{t_{i+1}}-Z_{t_i})^2,
\qquad t_i=\frac{it}{N}.
\]
\end{definition}

\begin{proposition}[Quadratic variation of an It\^o process]
If
\[
dZ_t=X_t\,dt+Y_t\,dB_t,
\]
then
\[
d\langle Z\rangle_t = Y_t^2\,dt,
\qquad
\langle Z\rangle_t = \int_0^t Y_s^2\,ds.
\]
\end{proposition}

\begin{theorem}[It\^o's formula for $f(Z_t)$]
Let
\[
dZ_t=X_t\,dt+Y_t\,dB_t,
\]
and let $f\in C^2(\mathbb R)$. Then
\[
df(Z_t)
=
\left(f'(Z_t)X_t+\frac12 f''(Z_t)Y_t^2\right)dt
+
f'(Z_t)Y_t\,dB_t.
\]
Equivalently,
\[
df(Z_t)=f'(Z_t)\,dZ_t+\frac12 f''(Z_t)\,d\langle Z\rangle_t.
\]
\end{theorem}

\begin{theorem}[Time-inhomogeneous It\^o formula]
Let
\[
dZ_t=X_t\,dt+Y_t\,dB_t,
\]
and let $f\in C^{1,2}$. Then
\[
df(t,Z_t)
=
\frac{\partial f}{\partial t}(t,Z_t)\,dt
+
\frac{\partial f}{\partial z}(t,Z_t)\,dZ_t
+
\frac12\frac{\partial^2 f}{\partial z^2}(t,Z_t)\,d\langle Z\rangle_t.
\]
Hence,
\[
df(t,Z_t)
=
\left(
\frac{\partial f}{\partial t}(t,Z_t)
+
X_t\frac{\partial f}{\partial z}(t,Z_t)
+
\frac12 Y_t^2\frac{\partial^2 f}{\partial z^2}(t,Z_t)
\right)dt
+
Y_t\frac{\partial f}{\partial z}(t,Z_t)\,dB_t.
\]
\end{theorem}

\begin{proposition}[Stochastic product rule]
If
\[
dZ_t^{(i)}=X_t^{(i)}\,dt+Y_t^{(i)}\,dB_t,
\qquad i=1,2,
\]
then
\[
d\bigl(Z_t^{(1)}Z_t^{(2)}\bigr)
=
Z_t^{(1)}\,dZ_t^{(2)}
+
Z_t^{(2)}\,dZ_t^{(1)}
+
d\langle Z^{(1)},Z^{(2)}\rangle_t,
\]
where
\[
d\langle Z^{(1)},Z^{(2)}\rangle_t = Y_t^{(1)}Y_t^{(2)}\,dt.
\]
\end{proposition}

\begin{proposition}[Exponential martingale]
For every $b\in\mathbb R$,
\[
\left(e^{\,bB_t-\frac12 b^2 t}\right)_{t\ge 0}
\]
is a martingale.
\end{proposition}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item computing
    \[
    \int_0^t B_s\,dB_s = \frac12 B_t^2 - \frac12 t;
    \]
    \item deriving martingales by killing the drift in It\^o's formula;
    \item converting right-endpoint Brownian sums into It\^o integral plus quadratic variation;
    \item computing moments or hitting quantities using reflection principle plus strong Markov.
\end{itemize}

\subsection{Lecture 10: SDE examples, Poisson processes, and CTMCs}

\begin{proposition}[Ornstein--Uhlenbeck process]
If $(Z_t)$ satisfies
\[
dZ_t=-Z_t\,dt+dB_t,
\]
then
\[
Z_t=e^{-t}\left(Z_0+\int_0^t e^s\,dB_s\right).
\]
In particular, $Z_t$ is Gaussian with mean $e^{-t}Z_0$ and variance
\[
e^{-2t}\int_0^t e^{2s}\,ds.
\]
\end{proposition}

\begin{proposition}[Geometric Brownian motion]
If $(Z_t)$ satisfies
\[
dZ_t=rZ_t\,dt+bZ_t\,dB_t,
\qquad Z_0>0,
\]
then
\[
Z_t = Z_0\exp\left(\left(r-\frac{b^2}{2}\right)t+bB_t\right).
\]
\end{proposition}

\begin{theorem}[Multidimensional It\^o formula]
Let $B_t=(B_t^{(1)},\dots,B_t^{(d)})$ be a $d$-dimensional Brownian motion with independent coordinates, and let
\[
dZ_t = X_t\,dt + Y_t\,dB_t,
\]
where $X_t\in\mathbb R^d$ and $Y_t\in\mathbb R^{d\times d}$. If $f\in C^{1,2}$, then
\[
df(t,Z_t)
=
\frac{\partial f}{\partial t}(t,Z_t)\,dt
+
\nabla f(t,Z_t)^\top dZ_t
+
\frac12 \operatorname{Tr}\!\left(Y_t^\top \nabla^2 f(t,Z_t)Y_t\right)dt.
\]
In the special case $Z_t=B_t$,
\[
df(t,B_t)
=
\frac{\partial f}{\partial t}(t,B_t)\,dt
+
\nabla f(t,B_t)^\top dB_t
+
\frac12 \Delta_x f(t,B_t)\,dt.
\]
\end{theorem}

\begin{definition}[Poisson process]
A process $(N(t))_{t\ge 0}$ is a Poisson process with intensity $\lambda>0$ if:
\begin{enumerate}[label=(\roman*)]
    \item $N(0)=0$;
    \item $N(t)$ has independent increments;
    \item for $0\le s<t$,
    \[
    N(t)-N(s)\sim \mathrm{Poi}(\lambda(t-s)).
    \]
\end{enumerate}
In particular,
\[
N(t)\sim \mathrm{Poi}(\lambda t).
\]
\end{definition}

\begin{proposition}[Basic properties of a Poisson process]
If $(N(t))$ is a Poisson process with intensity $\lambda$, then:
\begin{itemize}[leftmargin=2em]
    \item $N(t+s)-N(t)\sim \mathrm{Poi}(\lambda s)$ and is independent of the past;
    \item the interarrival times are i.i.d. $\mathrm{Exp}(\lambda)$;
    \item the process
    \[
    (N(t)-\lambda t)_{t\ge 0}
    \]
    is a martingale.
\end{itemize}
\end{proposition}

\begin{theorem}[Conditional law of arrival times]
Let $0<T_1<\cdots<T_{N(t)}\le t$ be the arrival times of a Poisson process on $[0,t]$. Conditional on $N(t)=n$, the unordered arrival times are i.i.d. $\mathrm{Unif}([0,t])$, and the ordered arrival times $(T_1,\dots,T_n)$ have the law of the order statistics of $n$ i.i.d. $\mathrm{Unif}([0,t])$ random variables.
\end{theorem}

\begin{definition}[Poisson point process]
Let $S$ be a measurable space with intensity function $\lambda(x)$. A Poisson point process on $S$ is a random counting measure $N$ such that for every measurable set $A\subseteq S$,
\[
N(A)\sim \mathrm{Poi}\!\left(\int_A \lambda(x)\,dx\right),
\]
and for disjoint measurable sets $A_1,\dots,A_m$, the random variables $N(A_1),\dots,N(A_m)$ are independent.
\end{definition}

\begin{proposition}[Superposition and thinning]
Let $(N_1(t))$ and $(N_2(t))$ be independent Poisson processes with intensities $\lambda_1$ and $\lambda_2$.
\begin{itemize}[leftmargin=2em]
    \item Then $(N_1(t)+N_2(t))$ is a Poisson process with intensity $\lambda_1+\lambda_2$.
    \item If $(N(t))$ is a Poisson process with intensity $\lambda$ and each arrival is independently labelled type $i$ with probability $p_i$, then the type-$i$ counting process is a Poisson process with intensity $\lambda p_i$, and these type processes are independent.
\end{itemize}
\end{proposition}

\begin{definition}[Continuous-time Markov chain]
A process $(X_t)_{t\ge 0}$ with values in a finite or countable state space $S$ is a continuous-time Markov chain if for every $s,t\ge 0$,
\[
\mathbb P(X_{t+s}=j\mid \mathcal F_t)=\mathbb P(X_{t+s}=j\mid X_t)
\qquad \text{a.s.}
\]
The transition probabilities are denoted
\[
p_{ij}^{(t)}:=\mathbb P(X_t=j\mid X_0=i).
\]
\end{definition}

\begin{definition}[Generator]
The generator $G=(g_{ij})_{i,j\in S}$ of a continuous-time Markov chain is defined by
\[
g_{ij}:=\lim_{t\downarrow 0}\frac{p_{ij}^{(t)}-\delta_{ij}}{t},
\]
whenever the limit exists.
\end{definition}

\begin{proposition}[Basic properties of the generator]
For every state $i\in S$,
\[
g_{ii}\le 0,
\qquad
g_{ij}\ge 0 \text{ for } j\neq i,
\qquad
\sum_{j\in S} g_{ij}=0.
\]
\end{proposition}

\begin{theorem}[Semigroup / matrix exponential relation]
If $G$ is the generator of a continuous-time Markov chain, then under the usual conditions,
\[
P^{(t)} = e^{tG}
\qquad \text{for all } t\ge 0,
\]
where
\[
e^{tG}=I+tG+\frac{t^2G^2}{2!}+\frac{t^3G^3}{3!}+\cdots.
\]
\end{theorem}

\textbf{Standard examples / exercises.}
\begin{itemize}[leftmargin=2em]
    \item computing expectations by conditioning on $N(t)$;
    \item using arrival-time uniformity on $[0,t]$;
    \item identifying whether a Poisson-process expression is a martingale;
    \item last-arrival / type-label problems via superposition-thinning;
    \item reading jump rates from a generator.
\end{itemize}

