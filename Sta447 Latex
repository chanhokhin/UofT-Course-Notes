\subsection*{Question 1 \hfill [30 points]}
Mark each of the following statements with T (true) or F (false). No justification is required.

\begin{enumerate}[label=(\arabic*)]
    \item For a discrete-time stochastic process \((X_n)_{n=0,1,2,\dots}\), if \(T_1\) and \(T_2\) are both stopping times satisfying \(T_1\ge T_2\), then \(T_1-T_2\) is a stopping time. \\
    \textbf{Answer:} F

    \item Let \(T_1,T_2,T_3\) be three stopping times. Let \(T_{(2)}\) be the second smallest one among \(T_1,T_2,T_3\). Then \(T_{(2)}\) is a stopping time. \\
    \textbf{Answer:} T

    \item Let
    \[
    T:=\min\{t\ge 10:X_t=X_{t-10}\}.
    \]
    The random time \(T\) is a stopping time. \\
    \textbf{Answer:} T

    \item If \((Z_i)_{i\ge 0}\) are i.i.d. zero-mean random variables, then the process
    \[
    X_n:=\left(\sum_{i=1}^n Z_i\right)^2-n\mathbb E[Z_0^2]
    \]
    is a martingale. \\
    \textbf{Answer:} T

    \item Let \((X_n)_{n\ge 0}\) be a discrete-time martingale such that \(X_n\ge 0\) for all \(n\). Then there exists a random variable \(X_\infty\) such that \(X_n\to X_\infty\) almost surely. \\
    \textbf{Answer:} T

    \item Let \((X_n)_{n=0,1,2,\dots}\) be a discrete-time martingale. If for any \(\varepsilon>0\) and any \(n\ge 0\), there exists a constant \(K>0\) depending on \(\varepsilon\) and \(n\) such that
    \[
    \mathbb E\bigl[|X_n|\mathbf 1_{\{|X_n|\ge K\}}\bigr]\le \varepsilon,
    \]
    then \((X_n)_{n\ge 0}\) is uniformly integrable. \\
    \textbf{Answer:} F

    \item Let \((X_n)_{n=0,1,2,\dots}\) be a martingale. If there exists a stopping time \(T\) such that
    \[
    \mathbb E[X_T]=\mathbb E[X_0],
    \]
    then \((X_n)_{n\ge 0}\) is uniformly integrable. \\
    \textbf{Answer:} F

    \item Let
    \[
    X_n:=\mathbb E[X\mid \mathcal F_n]
    \]
    for some random variable \(X\) and some filtration \((\mathcal F_n)_{n\ge 0}\), and let \(T\) be a stopping time. Then \(X_T\) is well-defined and
    \[
    \mathbb E[X_T]=\mathbb E[X_0].
    \]
    \textbf{Answer:} T

    \item Let \(Z_1,Z_2,\dots\) be i.i.d. random variables with finite mean \(\mu\). Let
    \[
    X_n:=\sum_{i=1}^n Z_i.
    \]
    Let
    \[
    T:=\arg\max_{1\le n\le 10} X_n.
    \]
    Then
    \[
    \mathbb E[X_T]=\mu \mathbb E[T].
    \]
    \textbf{Answer:} F

    \item Let \((X_n)_{n\ge 0}\) be a martingale satisfying
    \[
    \sup_{n\ge 0}\mathbb E[|X_n|^2]<+\infty.
    \]
    Then
    \[
    \mathbb E\left[\sup_{n\ge 0}|X_n|^2\right]<+\infty.
    \]
    \textbf{Answer:} T
\end{enumerate}

\textbf{Rubrics:} Each item is worth \(3\) points. No justification is required, and no partial credit is given.

\subsection*{Question 2 \hfill [24 points]}

Let \(X_0=1\) and
\[
X_t=W_tX_{t-1},
\]
where \(W_t\) are i.i.d. random variables with distribution
\[
W_t=
\begin{cases}
\frac32, & \text{with probability } \frac12,\\[0.4em]
\frac12, & \text{with probability } \frac12.
\end{cases}
\]
Define
\[
T_a:=\inf\{t>0:X_t\ge a\}
\]
for some constant \(a>1\).

\paragraph{Part (a) \hfill [9 pts]}
Is \((X_t)_{t\ge 0}\) uniformly integrable? How about the stopped process \((X_{t\wedge T_a})_{t\ge 0}\)? Justify your answer.

\textbf{Answer:}
Since \(\mathbb E[W_t]=1\), we have
\[
\mathbb E[X_t\mid \mathcal F_{t-1}]
=
X_{t-1}\mathbb E[W_t]
=
X_{t-1},
\]
so \((X_t)_{t\ge 0}\) is a nonnegative martingale with
\[
\mathbb E[X_t]=1
\qquad \text{for all } t.
\]

However,
\[
\log X_t=\sum_{i=1}^t \log W_i,
\]
and by the strong law of large numbers,
\[
\frac{1}{t}\log X_t
\to
\frac12\log\frac32+\frac12\log\frac12
=
\frac12\log\frac34
<0
\qquad \text{a.s.}
\]
Therefore
\[
X_t\to 0
\qquad \text{a.s.}
\]

If \((X_t)\) were uniformly integrable, then by the martingale convergence theorem we would have
\[
\mathbb E[X_\infty]=\lim_{t\to\infty}\mathbb E[X_t]=1,
\]
but \(X_\infty=0\) almost surely, a contradiction. Hence \((X_t)_{t\ge 0}\) is \emph{not} uniformly integrable.

For the stopped process, if \(t<T_a\), then \(X_t<a\). On the event \(\{T_a<+\infty\}\),
\[
X_{T_a}=W_{T_a}X_{T_a-1}\le \frac32 a
\]
because \(X_{T_a-1}<a\) and \(W_{T_a}\le 3/2\). Hence
\[
0\le X_{t\wedge T_a}\le \frac32 a
\qquad \text{for all } t.
\]
So \((X_{t\wedge T_a})_{t\ge 0}\) is a bounded martingale, and therefore uniformly integrable.

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(3\) points for showing that \(X_t\to 0\) almost surely, or giving an equivalent argument based on \(\sum_{i=1}^t \log W_i\).
    \item \(3\) points for concluding that \((X_t)\) is not uniformly integrable.
    \item \(3\) points for showing that \((X_{t\wedge T_a})\) is bounded, hence uniformly integrable.
\end{itemize}

\paragraph{Part (b) \hfill [9 pts]}
Show that
\[
\frac{2}{3a}\le \mathbb P(T_a<+\infty)\le \frac{1}{a}.
\]

\textbf{Answer:}
By part (a), the stopped process \((X_{t\wedge T_a})_{t\ge 0}\) is uniformly integrable, so we can invoke the optional stopping theorem for possibly infinite stopping times to get
\[
\mathbb E[X_{T_a}]=\mathbb E[X_0]=1.
\]
This can be rewritten as
\[
1
=
\mathbb E[X_{T_a}\mathbf 1_{\{T_a<+\infty\}}]
+
\mathbb E[X_{T_a}\mathbf 1_{\{T_a=+\infty\}}].
\]
Since
\[
X_{T_a}=\lim_{t\to\infty} X_{t\wedge T_a}=0
\qquad \text{on } \{T_a=+\infty\},
\]
we get
\[
1
=
\mathbb E[X_{T_a}\mid T_a<+\infty]\cdot \mathbb P(T_a<+\infty).
\]

On the event \(\{T_a<+\infty\}\), we have
\[
a\le X_{T_a}\le \frac32 a.
\]
Therefore,
\[
a\le \mathbb E[X_{T_a}\mid T_a<+\infty]\le \frac32 a.
\]
Substituting into the previous identity yields
\[
\frac{2}{3a}\le \mathbb P(T_a<+\infty)\le \frac{1}{a}.
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(4\) points for correctly applying optional stopping to get \(\mathbb E[X_{T_a}]=1\).
    \item If you get the correct equation without justifying OST, you can still get \(2\) points for this part.
    \item \(5\) points for using \(a\le X_{T_a}\le 3a/2\) on \(\{T_a<+\infty\}\) to derive both bounds.
    \item If only one side is proved correctly, you get \(3\) points out of \(5\) for this part.
\end{itemize}

\paragraph{Part (c) \hfill [6 pts]}
Define the random variable
\[
Z:=\max_{t\ge 0} X_t.
\]
Use the result in part (a) to show that
\[
\mathbb P(Z<+\infty)=1,
\qquad
\text{but}
\qquad
\mathbb E[Z]=+\infty.
\]

\textbf{Answer:}
From part (a), we know that
\[
X_t\to 0
\qquad \text{a.s.}
\]
Hence on every sample path there exists a random time \(N\) such that \(X_t\le 1\) for all \(t\ge N\). Therefore
\[
Z
=
\max_{t\ge 0}X_t
=
\max\{X_0,X_1,\dots,X_{N-1},\sup_{t\ge N}X_t\}
\]
is finite almost surely. Thus
\[
\mathbb P(Z<+\infty)=1.
\]

On the other hand, for every \(a>1\),
\[
\{Z\ge a\}=\{T_a<+\infty\}.
\]
So part (b) gives
\[
\mathbb P(Z\ge a)=\mathbb P(T_a<+\infty)\ge \frac{2}{3a}.
\]
Using the tail-sum lower bound for nonnegative random variables,
\[
\mathbb E[Z]
\ge
\sum_{k=2}^\infty \mathbb P(Z\ge k)
\ge
\sum_{k=2}^\infty \frac{2}{3k}
=+\infty.
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(3\) points for proving \(Z<+\infty\) almost surely, for example from \(X_t\to 0\) a.s.
    \item \(3\) points for proving \(\mathbb E[Z]=+\infty\) using the lower tail bound from part (b) and a tail-sum argument.
\end{itemize}

\subsection*{Question 3 \hfill [21 points]}

Let \((X_n)_{n\ge 0}\) be a one-dimensional symmetric simple random walk, i.e.
\[
X_0=0,
\qquad
X_n=\sum_{i=1}^n Z_i,
\]
where \(Z_i\) are i.i.d. random variables such that
\[
\mathbb P(Z_i=1)=\mathbb P(Z_i=-1)=\frac12.
\]
For \(\theta\in \mathbb R\), define
\[
\lambda(\theta):=\log\left(\frac12 e^\theta+\frac12 e^{-\theta}\right),
\]
and define
\[
M_n(\theta):=e^{\theta X_n-n\lambda(\theta)}.
\]

\paragraph{Part (a) \hfill [4 points]}
Prove that \((M_n(\theta))_{n\ge 0}\) is a martingale for any \(\theta\in\mathbb R\).

\textbf{Answer:}
Let
\[
\mathcal F_n=\sigma(Z_1,\dots,Z_n).
\]
Since \(X_n=X_{n-1}+Z_n\), we have
\[
\mathbb E[M_n(\theta)\mid \mathcal F_{n-1}]
=
\mathbb E\left[e^{\theta X_n-n\lambda(\theta)}\mid \mathcal F_{n-1}\right]
=
e^{\theta X_{n-1}-n\lambda(\theta)} \mathbb E[e^{\theta Z_n}\mid \mathcal F_{n-1}].
\]
Now
\[
\mathbb E[e^{\theta Z_n}\mid \mathcal F_{n-1}]
=
\frac12 e^\theta+\frac12 e^{-\theta}
=
e^{\lambda(\theta)}.
\]
Hence
\[
\mathbb E[M_n(\theta)\mid \mathcal F_{n-1}]
=
e^{\theta X_{n-1}-n\lambda(\theta)}e^{\lambda(\theta)}
=
e^{\theta X_{n-1}-(n-1)\lambda(\theta)}
=
M_{n-1}(\theta).
\]
Therefore \((M_n(\theta))_{n\ge 0}\) is a martingale.

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(2\) points for conditioning on \(\mathcal F_{n-1}\) and using \(X_n=X_{n-1}+Z_n\).
    \item \(2\) points for computing \(\mathbb E[e^{\theta Z_n}]=e^{\lambda(\theta)}\) and concluding the martingale property.
\end{itemize}

\paragraph{Part (b) \hfill [9 points]}
For a positive integer \(a\), define the stopping time
\[
T:=\inf\{n>0:|X_n|\ge a\}.
\]
Use the optional stopping theorem to show that
\[
\mathbb E\left[e^{-\lambda(\theta)T}\right]
=
\frac{2}{e^{\theta a}+e^{-\theta a}}.
\]

\textbf{Answer:}
Let \(\lambda=\lambda(\theta)\). Since \(T\) is the first time the walk exits
\[
\{-a+1,\dots,a-1\},
\]
we have
\[
|X_{n\wedge T}|\le a
\qquad \text{for every } n.
\]
Hence
\[
0\le M_{n\wedge T}(\theta)
=
e^{\theta X_{n\wedge T}-(n\wedge T)\lambda}
\le
e^{|\theta|a}.
\]
So \((M_{n\wedge T}(\theta))\) is bounded, and optional stopping gives
\[
\mathbb E[M_T(\theta)]=\mathbb E[M_0(\theta)]=1.
\]

Next we show that \(X_T\) is independent of \(T\). Since the walk moves by \(\pm 1\) and \(a\) is an integer, we must have
\[
X_T\in\{-a,a\}.
\]
For any fixed \(n\), there is a sign-flip bijection between paths of length \(n\) with \(T=n\) and \(X_T=a\), and paths of length \(n\) with \(T=n\) and \(X_T=-a\). Therefore
\[
\mathbb P(T=n,X_T=a)=\mathbb P(T=n,X_T=-a)=\frac12 \mathbb P(T=n).
\]
Thus \(X_T\) is independent of \(T\), and
\[
\mathbb P(X_T=a)=\mathbb P(X_T=-a)=\frac12.
\]

Now compute
\[
1=\mathbb E[M_T(\theta)]
=
\mathbb E[e^{\theta X_T-\lambda T}]
=
\mathbb E[e^{-\lambda T}]\,\mathbb E[e^{\theta X_T}].
\]
Also,
\[
\mathbb E[e^{\theta X_T}]
=
\frac12 e^{\theta a}+\frac12 e^{-\theta a}.
\]
Therefore
\[
1
=
\mathbb E[e^{-\lambda T}]
\cdot
\frac{e^{\theta a}+e^{-\theta a}}{2},
\]
so
\[
\mathbb E[e^{-\lambda(\theta)T}]
=
\frac{2}{e^{\theta a}+e^{-\theta a}}.
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(3\) points for correctly applying optional stopping to the stopped martingale.
    \item \(3\) points for showing that \(X_T\) is independent of \(T\), so that \(\mathbb P(X_T=\pm a)=1/2\).
    \item \(3\) points for computing \(\mathbb E[M_T(\theta)]\) and deriving the formula.
\end{itemize}

\paragraph{Part (c) \hfill [8 points]}
Fix \(\delta>0\) and \(n\in \mathbb N_+\). Show that
\[
\mathbb P\left(\max_{0\le t\le n} X_t \le \sqrt{2n\log(1/\delta)}\right)\ge 1-\delta.
\]

\textbf{Hint:} You may use without proof the calculus fact that
\[
\frac12 e^\theta+\frac12 e^{-\theta}\le e^{\theta^2/2}
\qquad \text{for any } \theta\in\mathbb R.
\]

\textbf{Answer:}
Fix \(\theta>0\) and \(b>0\). If
\[
\max_{0\le t\le n} X_t\ge b,
\]
then for some \(t\le n\),
\[
M_t(\theta)=e^{\theta X_t-t\lambda(\theta)}\ge e^{\theta b-n\lambda(\theta)},
\]
because \(t\le n\) and \(\lambda(\theta)\ge 0\). Therefore
\[
\left\{\max_{0\le t\le n} X_t\ge b\right\}
\subseteq
\left\{\max_{0\le t\le n} M_t(\theta)\ge e^{\theta b-n\lambda(\theta)}\right\}.
\]
Since \((M_t(\theta))_{0\le t\le n}\) is a nonnegative martingale, Doob's maximal inequality gives
\[
\mathbb P\left(\max_{0\le t\le n} X_t\ge b\right)
\le
\mathbb P\left(\max_{0\le t\le n} M_t(\theta)\ge e^{\theta b-n\lambda(\theta)}\right)
\le
e^{-\theta b+n\lambda(\theta)}\mathbb E[M_n(\theta)].
\]
But \(\mathbb E[M_n(\theta)]=1\), so
\[
\mathbb P\left(\max_{0\le t\le n} X_t\ge b\right)
\le
e^{-\theta b+n\lambda(\theta)}.
\]

Using the given inequality,
\[
\lambda(\theta)
=
\log\left(\frac12 e^\theta+\frac12 e^{-\theta}\right)
\le
\frac{\theta^2}{2}.
\]
Hence
\[
\mathbb P\left(\max_{0\le t\le n} X_t\ge b\right)
\le
e^{-\theta b+n\theta^2/2}.
\]
Choose
\[
\theta=\frac{b}{n}.
\]
Then
\[
\mathbb P\left(\max_{0\le t\le n} X_t\ge b\right)
\le
e^{-b^2/(2n)}.
\]
Now set
\[
b=\sqrt{2n\log(1/\delta)}.
\]
Then
\[
\mathbb P\left(\max_{0\le t\le n} X_t\ge \sqrt{2n\log(1/\delta)}\right)\le \delta,
\]
which is equivalent to
\[
\mathbb P\left(\max_{0\le t\le n} X_t \le \sqrt{2n\log(1/\delta)}\right)\ge 1-\delta.
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(4\) points for reducing the event \(\{\max_{t\le n}X_t\ge b\}\) to a maximal event for \(M_t(\theta)\) and applying Doob's inequality.
    \item \(2\) points for using \(\lambda(\theta)\le \theta^2/2\) to obtain an exponential bound.
    \item \(2\) points for optimizing in \(\theta\) and substituting \(b=\sqrt{2n\log(1/\delta)}\).
\end{itemize}

\subsection*{Question 4 \hfill [9 points]}

Let \(p\) be a probability distribution on \(\{0,1,2,\dots\}\) satisfying
\[
\mathbb E_{Z\sim p}[Z]=1.
\]
Consider a stochastic process \((X_n)_{n\ge 0}\) defined as follows:
\[
X_0=1,
\qquad
X_n=\sum_{i=1}^{X_{n-1}} Z_{n,i}
\quad (n\ge 1),
\]
where the \(Z_{n,i}\) are i.i.d. with law \(p\) and independent of \(X_{n-1}\). If \(X_n=0\) for some \(n\), then \(X_m=0\) for all \(m>n\).

Assuming that \(p\) is not the degenerate distribution putting all its mass on \(1\), show that
\[
\mathbb P(\text{the process goes extinct})=1.
\]

\textbf{Answer:}
Let
\[
\mathcal F_n=\sigma(Z_{k,i}:k\le n,\ i\ge 1).
\]
Since the \(Z_{n,i}\) are i.i.d. with mean \(1\) and are independent of \(X_{n-1}\),
\[
\mathbb E[X_n\mid \mathcal F_{n-1}]
=
\mathbb E\left[\sum_{i=1}^{X_{n-1}} Z_{n,i}\,\middle|\, \mathcal F_{n-1}\right]
=
X_{n-1}\cdot \mathbb E[Z]
=
X_{n-1}.
\]
Hence \((X_n)_{n\ge 0}\) is a martingale.

Since \(X_n\ge 0\) for all \(n\) and
\[
\sup_n \mathbb E[X_n]=\mathbb E[X_0]=1<\infty,
\]
it is a nonnegative \(L^1\)-bounded martingale. By the martingale convergence theorem,
\[
X_n\to X_\infty
\qquad \text{a.s.}
\]
for some nonnegative random variable \(X_\infty\).

Now \(X_n\in \{0,1,2,\dots\}\) for every \(n\). A sequence of integers can converge only if it is eventually constant. So almost surely,
\[
X_n=X_\infty
\qquad \text{for all sufficiently large } n.
\]

For \(k\ge 1\), if \(X_n=k\), then
\[
X_{n+1}=\sum_{i=1}^k Z_{n+1,i},
\]
which has mean \(k\) and variance
\[
k\,\mathrm{Var}(Z)>0,
\]
since \(p\) is not degenerate at \(1\). Therefore \(X_{n+1}\) is not almost surely equal to \(k\). So \(k\) is not an absorbing state and cannot be the eventual constant value of the process. Hence
\[
\mathbb P(X_\infty=k)=0
\qquad \text{for every } k\ge 1.
\]
Therefore
\[
X_\infty=0
\qquad \text{a.s.}
\]
So the process goes extinct with probability \(1\).

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(4\) points for identifying \((X_n)\) as a nonnegative martingale and applying the martingale convergence theorem to obtain an a.s. limit \(X_\infty\).
    \item \(3\) points for arguing that \(X_\infty\) is integer-valued and therefore eventually constant.
    \item \(2\) points for showing that the only possible eventual constant value is zero.
\end{itemize}

\subsection*{Question 5 \hfill [16 points]}
\textbf{Sum of independent random variables}

\paragraph{Part (a) \hfill [8 points]}
Let \((X_n)_{n\ge 0}\) be i.i.d. normal random variables with mean \(0\) and variance \(1\). Define
\[
S_n=\sum_{i=1}^n X_i^2.
\]
Fix \(a>0\), and define the stopping time
\[
T:=\inf\{n>0:|X_n|\ge a\}.
\]
Compute \(\mathbb E[S_T]\). You may express the answer using the cumulative distribution function \(\Phi\) of the standard normal distribution.

\textbf{Answer:}
Let
\[
p:=\mathbb P(|X_1|\ge a)=2(1-\Phi(a)).
\]
Since the \(X_n\) are i.i.d., the stopping time \(T\) is geometric with success probability \(p\). Thus
\[
\mathbb E[T]=\frac{1}{p}=\frac{1}{2(1-\Phi(a))}.
\]

Now
\[
S_T=\sum_{i=1}^T X_i^2,
\]
and the \(X_i^2\) are i.i.d., nonnegative, with mean
\[
\mathbb E[X_1^2]=1.
\]
Therefore Wald's identity gives
\[
\mathbb E[S_T]=\mathbb E[T]\mathbb E[X_1^2]
=
\frac{1}{2(1-\Phi(a))}.
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(3\) points for identifying \(T\) as a geometric random variable with parameter \(2(1-\Phi(a))\).
    \item \(5\) points for correctly applying Wald's identity, or an equivalent argument, to obtain
    \[
    \mathbb E[S_T]=\frac{1}{2(1-\Phi(a))}.
    \]
\end{itemize}

\paragraph{Part (b) \hfill [8 points]}
Let \((Y_n)_{n\ge 0}\) be i.i.d. random variables with
\[
\mathbb P(Y_n=1)=\mathbb P(Y_n=-1)=\frac12.
\]
Define
\[
Z_n:=\sum_{i=1}^n 2^{i-1}Y_i.
\]
Define the stopping time
\[
T:=\inf\{n>0:Y_n>0\}.
\]
Compute \(\mathbb E[T]\), and show that
\[
\mathbb E[Z_T]\ne \mathbb E[Z_0].
\]

\textbf{Answer:}
Since \(T\) is the first time that \(Y_n=1\), it is geometric with parameter \(1/2\). Hence
\[
\mathbb E[T]=\frac{1}{1/2}=2.
\]

On the event \(\{T=t\}\), we must have
\[
Y_1=Y_2=\cdots=Y_{t-1}=-1,
\qquad
Y_t=1.
\]
Therefore
\[
Z_T
=
\sum_{i=1}^{t-1}2^{i-1}(-1)+2^{t-1}
=
-\sum_{i=1}^{t-1}2^{i-1}+2^{t-1}.
\]
Since
\[
\sum_{i=1}^{t-1}2^{i-1}=2^{t-1}-1,
\]
we get
\[
Z_T=-(2^{t-1}-1)+2^{t-1}=1.
\]
So
\[
Z_T=1
\qquad \text{a.s.}
\]
and hence
\[
\mathbb E[Z_T]=1.
\]

But
\[
Z_0=0,
\]
so
\[
\mathbb E[Z_T]=1\ne 0=\mathbb E[Z_0].
\]

\textbf{Rubrics:}
\begin{itemize}[leftmargin=2em]
    \item \(3\) points for correctly computing \(\mathbb E[T]=2\).
    \item \(5\) points for showing that \(Z_T=1\) almost surely and therefore \(\mathbb E[Z_T]\ne \mathbb E[Z_0]\).
\end{itemize}

