\section{Important Theorems for Midterms and Finals}

\begin{summarybox}
This section gives the \emph{actual theorem statements} and core formulas, rather than only listing theorem names. I only include the results that were directly used, quoted, or heavily relied on in the midterms and the two finals.
\end{summarybox}

\subsection{Discrete-time Markov chains}

\begin{proposition}[First-step expansion for hitting probabilities]
Let $A\subseteq S$ and define
\[
T_A:=\inf\{n\ge 0:X_n\in A\}.
\]
Let
\[
u_i:=\mathbb P_i(T_A<\infty).
\]
Then
\[
\nu_i=1 \quad \text{for } i\in A,
\]
and for every $i\notin A$,
\[
\nu_i = \sum_{j\in S} p_{ij}\,\nu_j.
\]
In particular, for a single target state $j$,
\[
f_{ij}=p_{ij}+\sum_{k\neq j} p_{ik}f_{kj}.
\]
\end{proposition}

\emph{Most relevant for:} Midterm 1 hitting-probability questions, Final 2024 Question 2(1), Final 2025 Question 2(2).

\begin{proposition}[First-step expansion for expected hitting times]
Let $A\subseteq S$ and define
\[
T_A:=\inf\{n\ge 0:X_n\in A\}.
\]
If
\[
h_i:=\mathbb E_i[T_A]
\]
is finite, then
\[
h_i=0 \quad \text{for } i\in A,
\]
and for every $i\notin A$,
\[
h_i = 1 + \sum_{j\in S} p_{ij} h_j.
\]
\end{proposition}

\emph{Most relevant for:} standard boundary-value computations for hitting times and return times.

\begin{proposition}[Expected number of visits]
Fix $j\in S$, and define the total number of visits to $j$ by
\[
N(j):=\sum_{n=0}^{\infty} \mathbf 1_{\{X_n=j\}}.
\]
Then for every starting state $i$,
\[
\mathbb E_i[N(j)] = \sum_{n=0}^{\infty} p_{ij}^{(n)}.
\]
If $j$ is transient, then
\[
\mathbb E_j[N(j)] = \frac{1}{1-f_{jj}},
\qquad
\mathbb E_i[N(j)] = \frac{f_{ij}}{1-f_{jj}}.
\]
\end{proposition}

\emph{Most relevant for:} Midterm 1 and true/false questions on recurrence/transience.

\begin{theorem}[Recurrence criterion]
For a state $i$, the following are equivalent:
\begin{enumerate}[label=(\roman*)]
    \item $i$ is recurrent;
    \item $\sum_{n=1}^{\infty} p_{ii}^{(n)} = \infty$;
    \item $\mathbb P_i(X_n=i \text{ infinitely often}) = 1$.
\end{enumerate}
Also, the following are equivalent:
\begin{enumerate}[label=(\roman*)]
    \item $i$ is transient;
    \item $\sum_{n=1}^{\infty} p_{ii}^{(n)} < \infty$;
    \item $\mathbb P_i(X_n=i \text{ infinitely often}) = 0$.
\end{enumerate}
\end{theorem}

\emph{Most relevant for:} Midterm 1 Question 1, Final 2024 Question 1, Final 2025 Questions 1 and 3.

\begin{theorem}[Class property in irreducible chains]
If a Markov chain is irreducible, then recurrence/transience is a class property: either every state is recurrent, or every state is transient. Moreover, positive recurrence is also a class property: if one state is positive recurrent, then every state is positive recurrent.
\end{theorem}

\emph{Most relevant for:} many true/false questions and all irreducible-chain classification problems.

\begin{proposition}[Detailed balance implies stationarity]
Let $\mu=(\mu_i)_{i\in S}$ be a nonnegative measure on $S$. If
\[
\mu_i p_{ij} = \mu_j p_{ji}
\qquad \text{for all } i,j\in S,
\]
then $\mu$ is a stationary measure, i.e.
\[
\mu P = \mu.
\]
If in addition $\sum_{i\in S} \mu_i < \infty$, then the normalized vector
\[
\pi_i := \frac{\mu_i}{\sum_{k\in S} \mu_k}
\]
is a stationary distribution.
\end{proposition}

\emph{Most relevant for:} birth--death chains and reversible chains, especially Final 2024 Question 3 and Final 2025 Question 3.

\begin{theorem}[Markov chain convergence theorem]
Suppose a Markov chain on a finite or countable state space is irreducible, aperiodic, and positive recurrent, with stationary distribution $\pi$. Then for every $i,j\in S$,
\[
\lim_{n\to\infty} p_{ij}^{(n)} = \pi_j.
\]
\end{theorem}

\emph{Most relevant for:} Midterm 1 convergence questions and Final 2024 Question 3.

\begin{theorem}[Recurrence time theorem]
Suppose a Markov chain is irreducible and positive recurrent, with stationary distribution $\pi$. Define the first return time to $i$ by
\[
T_i^+ := \inf\{n\ge 1:X_n=i\}.
\]
Then
\[
\mathbb E_i[T_i^+] = \frac{1}{\pi_i}.
\]
\end{theorem}

\emph{Most relevant for:} Final 2025 Question 2(1), and any expected-return-time computation once $\pi$ is known.

\begin{proposition}[Stationary distributions in finite reducible chains]
For a finite-state Markov chain, every stationary distribution assigns zero mass to transient states. If the chain has closed communicating classes $C_1,\dots,C_m$, and each $C_r$ has stationary distribution $\pi^{(r)}$ on that class, then every stationary distribution of the whole chain is of the form
\[
\pi = \sum_{r=1}^m \alpha_r \pi^{(r)},
\qquad
\alpha_r\ge 0,
\qquad
\sum_{r=1}^m \alpha_r=1.
\]
\end{proposition}

\emph{Most relevant for:} Final 2024 Question 2(2).

\begin{proposition}[Exam-style Foster--Lyapunov recurrence criterion]
Let $(X_n)$ be an irreducible Markov chain on $\{0,1,2,\dots\}$ such that $|X_{n+1}-X_n|\le 1$ almost surely. Suppose there exists a nonnegative, strictly increasing function $V$ with $V(x)\to\infty$ as $x\to\infty$, and a constant $K<\infty$, such that
\[
\sum_{j\in S} p_{ij}V(j)=V(i)
\qquad \text{for every } i>K,
\]
and
\[
\sum_{j\in S} p_{ij}V(j)<\infty
\qquad \text{for } i=0,1,\dots,K.
\]
Then the chain is recurrent.
\end{proposition}

\begin{proposition}[Exam-style Foster--Lyapunov positive recurrence criterion]
Under the same setup, if there exist $K<\infty$ and $\varepsilon>0$ such that
\[
\sum_{j\in S} p_{ij}V(j) \le V(i)-\varepsilon
\qquad \text{for every } i>K,
\]
and
\[
\sum_{j\in S} p_{ij}V(j)<\infty
\qquad \text{for } i=0,1,\dots,K,
\]
then the chain is positive recurrent. In particular, it has a stationary distribution.
\end{proposition}

\emph{Most relevant for:} Final 2024 Question 6.

\subsection{Martingales, stopping times, and convergence}

\begin{definition}[Stopping time]
A random time $T$ is a stopping time with respect to a filtration $(\mathcal F_n)$ if for every $n$,
\[
\{T\le n\}\in \mathcal F_n.
\]
Equivalently, whether or not $T\le n$ can be decided using only information available by time $n$.
\end{definition}

\emph{Most relevant for:} Midterm 2 Question 1, Final 2024 Question 1(4), Final 2025 Question 1(4).

\begin{theorem}[Optional stopping theorem: bounded-time version]
Let $(M_n,\mathcal F_n)$ be a martingale, and let $T$ be a bounded stopping time. Then
\[
\mathbb E[M_T] = \mathbb E[M_0].
\]
More generally, if $(M_n)$ is a supermartingale, then
\[
\mathbb E[M_T] \le \mathbb E[M_0].
\]
\end{theorem}

\begin{theorem}[Optional stopping theorem: common unbounded-time version]
Let $(M_n,\mathcal F_n)$ be a martingale and let $T$ be a stopping time with $T<\infty$ almost surely. If the stopped process $(M_{n\wedge T})_{n\ge 0}$ is uniformly integrable, then
\[
\mathbb E[M_T] = \mathbb E[M_0].
\]
A standard way to verify this in practice is to show that the family $\{M_{n\wedge T}:n\ge 0\}$ is dominated in $L^1$ by an integrable random variable.
\end{theorem}

\emph{Most relevant for:} Midterm 2 Questions 2, 3, 5; Final 2024 Question 4(4); Final 2025 Question 4(4).

\begin{theorem}[Nonnegative supermartingale convergence theorem]
If $(M_n,\mathcal F_n)$ is a nonnegative supermartingale, then there exists an integrable random variable $M_\infty$ such that
\[
M_n \to M_\infty
\qquad \text{almost surely.}
\]
In particular, every nonnegative martingale converges almost surely.
\end{theorem}

\emph{Most relevant for:} Midterm 2 convergence questions, Final 2025 Question 1(5), Final 2025 Question 6(1).

\begin{theorem}[Uniform integrability and $L^1$ convergence]
Let $(M_n,\mathcal F_n)$ be a martingale.
\begin{enumerate}[label=(\roman*)]
    \item If $(M_n)$ is uniformly integrable and $M_n\to M_\infty$ almost surely, then
    \[
    M_n \to M_\infty \quad \text{in } L^1,
    \]
    and
    \[
    M_n = \mathbb E[M_\infty\mid \mathcal F_n].
    \]
    \item If $Y\in L^1$ and $M_n:=\mathbb E[Y\mid \mathcal F_n]$, then $(M_n)$ is a uniformly integrable martingale.
\end{enumerate}
\end{theorem}

\emph{Most relevant for:} Midterm 2 UI questions and Final 2025 Question 6(3).

\begin{theorem}[Doob's maximal inequality]
If $(M_n)_{n=0}^N$ is a nonnegative submartingale and $\lambda>0$, then
\[
\mathbb P\!\left(\max_{0\le k\le N} M_k \ge \lambda\right)
\le
\frac{\mathbb E[M_N]}{\lambda}.
\]
\end{theorem}

\emph{Most relevant for:} Midterm 2 maximum-control problems.

\begin{theorem}[Wald's identity]
Let $Z_1,Z_2,\dots$ be i.i.d. integrable random variables, let
\[
S_n:=\sum_{k=1}^n Z_k,
\]
and let $T$ be a stopping time for the natural filtration of $(Z_k)$.
Under the standard hypotheses ensuring optional stopping for the martingale
\[
S_n - n\,\mathbb E[Z_1],
\]
we have
\[
\mathbb E[S_T] = \mathbb E[T]\,\mathbb E[Z_1].
\]
In particular, this holds whenever $T$ is bounded; it also holds under the usual integrability hypotheses from class.
\end{theorem}

\emph{Most relevant for:} Midterm 2 Question 5.

\subsection{Brownian motion and stochastic calculus}

\begin{theorem}[Reflection principle]
Let $(B_t)_{t\ge 0}$ be standard Brownian motion, and fix $a>0$ and $t>0$. Then
\[
\mathbb P\!\left(\max_{0\le s\le t} B_s \ge a\right)
= 2\,\mathbb P(B_t\ge a).
\]
More generally, for $x>0$ and $y<x$,
\[
\mathbb P\!\left(\max_{0\le s\le t} B_s > x,\ B_t<y\right)
=
\mathbb P(B_t>2x-y).
\]
\end{theorem}

\emph{Most relevant for:} Final 2024 Question 4(2), Final 2025 Question 4(3).

\begin{theorem}[Strong Markov property of Brownian motion]
Let $T$ be a stopping time for the Brownian filtration, with $T<\infty$ almost surely. Then the shifted process
\[
\widetilde B_t := B_{T+t}-B_T,
\qquad t\ge 0,
\]
is a standard Brownian motion independent of $\mathcal F_T$.
\end{theorem}

\emph{Most relevant for:} Final 2025 Question 4(3), and many hitting-time arguments.

\begin{theorem}[Quadratic variation]
For standard Brownian motion,
\[
\langle B\rangle_t = t.
\]
More generally, if
\[
X_t = X_0 + \int_0^t b_s\,ds + \int_0^t \sigma_s\,dB_s,
\]
then
\[
\langle X\rangle_t = \int_0^t \sigma_s^2\,ds.
\]
Equivalently, in differential form,
\[
d\langle X\rangle_t = \sigma_t^2\,dt.
\]
\end{theorem}

\emph{Most relevant for:} Final 2024 Question 4(1), Final 2025 Question 4(1)--(2).

\begin{theorem}[It\^o's formula]
Let
\[
X_t = X_0 + \int_0^t b_s\,ds + \int_0^t \sigma_s\,dB_s,
\]
and let $f\in C^{1,2}([0,\infty)\times\mathbb R)$. Then
\[
\begin{aligned}
f(t,X_t)
&= f(0,X_0)
+ \int_0^t \frac{\partial f}{\partial s}(s,X_s)\,ds
+ \int_0^t \frac{\partial f}{\partial x}(s,X_s)\,dX_s \\
&\qquad
+ \frac12 \int_0^t \frac{\partial^2 f}{\partial x^2}(s,X_s)\,d\langle X\rangle_s.
\end{aligned}
\]
Equivalently,
\[
\begin{aligned}
df(t,X_t)
&=
\left(
\frac{\partial f}{\partial t}(t,X_t)
+ b_t\frac{\partial f}{\partial x}(t,X_t)
+ \frac12 \sigma_t^2 \frac{\partial^2 f}{\partial x^2}(t,X_t)
\right)dt \\
&\qquad + \sigma_t\frac{\partial f}{\partial x}(t,X_t)\,dB_t.
\end{aligned}
\]
\end{theorem}

\emph{Most relevant for:} Final 2024 Question 4(1), (3), (4); Final 2025 Question 4(1), (2), (4).

\begin{proposition}[It\^o integrals are martingales]
If $(Y_t)_{t\ge 0}$ is adapted and satisfies
\[
\mathbb E\!\left[\int_0^t Y_s^2\,ds\right] < \infty,
\]
then the process
\[
M_t := \int_0^t Y_s\,dB_s
\]
is a martingale, and
\[
\mathbb E[M_t]=0.
\]
Also, the It\^o isometry holds:
\[
\mathbb E[M_t^2] = \mathbb E\!\left[\int_0^t Y_s^2\,ds\right].
\]
\end{proposition}

\emph{Most relevant for:} turning a drift-corrected quantity into a martingale after applying It\^o's formula.

\begin{proposition}[Brownian exponential martingale]
For every $\theta\in\mathbb R$, the process
\[
M_t := \exp\!\left(\theta B_t - \frac12 \theta^2 t\right)
\]
is a martingale.
\end{proposition}

\emph{Most relevant for:} Midterm 2 exponential-martingale problems and Final 2024 Question 4(3)--(4).

\subsection{Poisson processes}

\begin{definition}[Poisson process with rate $\lambda$]
A counting process $(N(t))_{t\ge 0}$ is a Poisson process with intensity $\lambda>0$ if
\begin{enumerate}[label=(\roman*)]
    \item $N(0)=0$;
    \item it has independent increments;
    \item for $0\le s<t$,
    \[
    N(t)-N(s)\sim \mathrm{Poisson}(\lambda(t-s)).
    \]
\end{enumerate}
\end{definition}

\begin{proposition}[Compensated Poisson martingale]
If $(N(t))_{t\ge 0}$ is a Poisson process with rate $\lambda$, then
\[
M_t := N(t)-\lambda t
\]
is a martingale.
\end{proposition}

\emph{Most relevant for:} truth/false questions and checking whether a proposed process is a martingale.

\begin{theorem}[Conditional law of arrival times given $N(t)=n$]
Let $0<T_1<\cdots<T_{N(t)}\le t$ be the arrival times of a Poisson process in $[0,t]$. Conditionally on $N(t)=n$, the ordered vector $(T_1,\dots,T_n)$ has joint density
\[
(t_1,\dots,t_n) \mapsto \frac{n!}{t^n}
\quad \text{on } 0<t_1<\cdots<t_n<t.
\]
Equivalently, conditionally on $N(t)=n$, the ordered arrival times are the order statistics of $n$ i.i.d. $\mathrm{Unif}[0,t]$ random variables.
\end{theorem}

\emph{Most relevant for:} Final 2025 Question 5.

\begin{theorem}[Superposition of independent Poisson processes]
If $(N_1(t))_{t\ge 0}$ and $(N_2(t))_{t\ge 0}$ are independent Poisson processes with rates $\lambda_1$ and $\lambda_2$, then
\[
N(t):=N_1(t)+N_2(t)
\]
is a Poisson process with rate $\lambda_1+\lambda_2$.
\end{theorem}

\begin{theorem}[Poisson thinning / type-labeling]
Let $(N(t))_{t\ge 0}$ be a Poisson process with rate $\lambda$. Independently for each arrival, assign type $1$ with probability $p$ and type $2$ with probability $1-p$. Let $N_1(t)$ and $N_2(t)$ be the numbers of arrivals of each type up to time $t$. Then
\[
N_1 \sim \mathrm{PP}(\lambda p),
\qquad
N_2 \sim \mathrm{PP}(\lambda(1-p)),
\]
and $N_1$ and $N_2$ are independent.
\end{theorem}

\emph{Most relevant for:} Final 2024 Question 5.

\subsection{A few formulas that were especially exam-relevant}

\begin{keyformula}
For a birth--death chain, detailed balance usually starts from
\[
\pi_i p_{i,i+1} = \pi_{i+1} p_{i+1,i}.
\]
Once you get a recursive formula for $\pi_i$, the only remaining step is normalization.
\end{keyformula}

\begin{keyformula}
If you want a martingale from Brownian motion, a very common pattern is:
\begin{enumerate}[label=(\roman*)]
    \item guess a function $f(t,x)$;
    \item apply It\^o's formula to $f(t,X_t)$;
    \item choose $f$ so that the $dt$ term disappears.
\end{enumerate}
Then the remainder is an It\^o integral, hence a martingale.
\end{keyformula}

\begin{keyformula}
If you want to use optional stopping, the real question is never just ``is $M_t$ a martingale?'' The real question is whether the stopped family is integrable enough for OST to be valid.
\end{keyformula}

