\subsection*{Question 1 \hfill [20 points]}
Mark each of the following statements with T (true) or F (false).

\begin{enumerate}[label=(\arabic*)]
    \item Let $P$ be an irreducible and transient discrete-time Markov chain. For any state pair $i,j\in S$, we have $f_{ij}<1$.
    \textbf{Answer:} F.

    \emph{Explanation.} In an irreducible transient chain, it can still happen that one state hits another almost surely. The standard counterexample is biased random walk on $\mathbb Z$ with drift to the right: starting from $0$, the walk hits $1$ almost surely, but the chain is still transient.

    \item Let $i,j,k,\ell$ be states in a discrete-time discrete-space Markov chain. If $i\to j$ and $k\to \ell$, and if
    \[
    \sum_{n\ge 0} p_{i\ell}^{(n)}<\infty,
    \]
    then
    \[
    \sum_{n\ge 0} p_{jk}^{(n)}<\infty.
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} The assumption $\sum_n p_{i\ell}^{(n)}<\infty$ implies that state $\ell$ is transient. Since $k\to \ell$, the state $k$ must also be transient. Once $k$ is transient, the expected number of visits to $k$ starting from any state $j$ is finite, so
    \[
    \sum_{n\ge 0} p_{jk}^{(n)}<\infty.
    \]

    \item Let $P$ be an irreducible Markov chain. If $P$ is positive recurrent, then for any $i,j$,
    \[
    \mathbb E_i[T_j] < \infty.
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} In an irreducible positive recurrent chain, all states communicate and return times have finite expectations. Hitting times between states are also finite in expectation.

    \item Let $(X_k)_{k\ge 0}$ be symmetric simple random walk, and define
    \[
    T:=\sup\{t\in[0,100]: X_t=0\}.
    \]
    Then $T$ is a stopping time.
    \textbf{Answer:} F.

    \emph{Explanation.} To know whether $T\le n$, one must know whether the walk ever returns to $0$ after time $n$. That requires future information, so $T$ is not a stopping time.

    \item Let $(X_k)_{k\ge 0}$ be a martingale such that $X_k\ge -20$ almost surely for every $k$. Then there exists $X_\infty$ such that
    \[
    X_n\to X_\infty \qquad \text{a.s.}
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} The shifted process $Y_k:=X_k+20$ is a nonnegative martingale. Every nonnegative martingale converges almost surely, so $Y_k\to Y_\infty$ a.s. and therefore $X_k\to X_\infty:=Y_\infty-20$ a.s.

    \item Let $(B(t))_{t\ge 0}$ be standard Brownian motion. Then
    \[
    \int_0^t dB(s)=B(t).
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} This is the It\^o integral with constant integrand $1$. By definition,
    \[
    \int_0^t 1\,dB(s)=B(t)-B(0)=B(t),
    \]
    since $B(0)=0$.

    \item For $i=1,2,3$, let $(B^{(i)}(t))_{t\ge 0}$ be independent standard Brownian motions. Define
    \[
    T:=\inf\{t\ge 0: B^{(i)}(t)\in[10,11] \text{ for } i=1,2,3\}.
    \]
    Then $\mathbb P(T<\infty)=1$.
    \textbf{Answer:} F.

    \emph{Explanation.} The three-dimensional process
    \[
    (B^{(1)}(t),B^{(2)}(t),B^{(3)}(t))
    \]
    is standard Brownian motion in $\mathbb R^3$. The event in the statement says this $3$-dimensional Brownian motion hits the box $[10,11]^3$. Brownian motion in dimension $3$ is transient, so the probability of hitting a fixed bounded set is strictly less than $1$.

    \item Let $(N(t))_{t\ge 0}$ be a Poisson process with intensity $1$. Let
    \[
    X(t)=N(t)^2-(t+t^2).
    \]
    Then $(X(t))_{t\ge 0}$ is a martingale.
    \textbf{Answer:} F.

    \emph{Explanation.} The term $t+t^2$ only centers the one-time marginal because
    \[
    \mathbb E[N(t)^2]=t+t^2.
    \]
    But being mean zero at each time is not enough for the martingale property. The correct quadratic martingale for Poisson process includes the linear compensator coming from the jump structure, not just $t+t^2$.
