\subsection*{Question 1 \hfill [20 points]}
Mark each of the following statements with T (true) or F (false).

\begin{enumerate}[label=(\arabic*)]
    \item Let $P$ be an irreducible and transient Markov chain. For any state pair $i,j\in S$, we have
    \[
    \sum_{n\ge 0} p_{ij}^{(n)}<\infty.
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} In an irreducible chain, transience is a class property. So if the chain is transient, then every state is transient. For a transient state $j$, the expected total number of visits to $j$ starting from any $i$ is finite, and that expectation is exactly
    \[
    \mathbb E_i[N(j)] = \sum_{n\ge 0} p_{ij}^{(n)}.
    \]

    \item Let $P$ be a reducible and aperiodic Markov chain on a finite state space $S$. Let $i$ be a transient state. Then there exists a stationary distribution $\pi$ of $P$ such that
    \[
    \lim_{n\to\infty} p_{ij}^{(n)} = \pi_j, \qquad \text{for each } j\in S.
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} In a finite state space, probability mass eventually leaves transient states and ends up inside recurrent classes. A reducible finite chain can have several closed recurrent classes, and one can choose a stationary distribution supported on the classes that are reached from $i$ with the correct absorption probabilities. Then the limit distribution of the chain started from $i$ agrees with that stationary distribution.

    \item Let $i,j$ be a pair of states in a discrete-time Markov chain. If $f_{ij}=1$, then the chain starting from $i$ will visit $j$ infinitely often.
    \textbf{Answer:} F.

    \emph{Explanation.} The condition $f_{ij}=1$ only says that $j$ is hit at least once almost surely. It does \emph{not} imply infinitely many visits. A standard counterexample is biased random walk on $\mathbb Z$ with positive drift: starting from $0$ it hits $1$ almost surely, but the walk is transient, so each fixed state is visited only finitely many times almost surely.

    \item Let $(X_k)_{k\ge 0}$ be a real-valued stochastic process. Define
    \[
    T:=\inf\left\{t\ge 5: X_t = \max_{0\le k\le t} X_k\right\}.
    \]
    Then $T$ is a stopping time.
    \textbf{Answer:} T.

    \emph{Explanation.} To decide whether $T\le n$, one only needs the sample values $X_0,\dots,X_n$. Indeed,
    \[
    \{T\le n\}
    =
    \bigcup_{t=5}^n \left\{X_t = \max_{0\le k\le t} X_k\right\},
    \]
    and each event on the right is measurable with respect to the information available by time $n$.

    \item Let $(X_k)_{k\ge 0}$ be a martingale that converges to $X_\infty$. Suppose that
    \[
    \mathbb E[X_k^2] < \infty, \qquad \text{for every } k\ge 0.
    \]
    Then
    \[
    \mathbb E[X_\infty] = \mathbb E[X_0].
    \]
    \textbf{Answer:} F.

    \emph{Explanation.} Having finite second moment at each fixed time is not enough. What is needed is a stronger condition such as uniform integrability or a uniform $L^2$ bound:
    \[
    \sup_k \mathbb E[X_k^2] < \infty.
    \]
    Without such a uniform bound, the limit may fail to preserve expectation.

    \item Let $(B(t))_{t\ge 0}$ be standard Brownian motion. Define $t_{n,i}:=i/n$ for $i=0,1,\dots,n$. Then
    \[
    \int_0^1 B(s)\,ds
    =
    \lim_{n\to\infty}
    \sum_{i=0}^{n-1}
    B\!\left(\frac{t_{n,i}+t_{n,i+1}}{2}\right)
    (t_{n,i+1}-t_{n,i}).
    \]
    \textbf{Answer:} T.

    \emph{Explanation.} This is an ordinary Riemann integral in time, not an It\^o integral. Since Brownian sample paths are continuous, midpoint Riemann sums converge to the usual integral $\int_0^1 B(s)\,ds$.

    \item Let $(B(t))_{t\ge 0}$ be standard Brownian motion, and define
    \[
    S:=\{t\in[0,1]: B(t)=1\}.
    \]
    Then
    \[
    \mathbb P(|S|=1)>0.
    \]
    \textbf{Answer:} F.

    \emph{Explanation.} Brownian motion is continuous and highly oscillatory. If it hits level $1$ inside $[0,1]$, the hitting set is almost surely not a singleton. So the event ``hit level $1$ exactly once'' has probability $0$.

    \item Let $(N(t))_{t\ge 0}$ be a Poisson process with intensity $\lambda>0$. Define
    \[
    X = N(3)-N(2),
    \qquad
    Y = N(1)+N(4)-N(3).
    \]
    Then $X$ and $Y$ are independent.
    \textbf{Answer:} T.

    \emph{Explanation.} We can rewrite
    \[
    Y = N(1) + (N(4)-N(3)).
    \]
    The random variable $X$ depends only on the increment over $(2,3]$, while $Y$ depends only on the disjoint intervals $[0,1]$ and $(3,4]$. By independent increments of the Poisson process, $X$ is independent of $Y$.
\end{enumerate}

\subsection*{Question 2 \hfill [14 points]}
Consider the Markov chain on $S=\{1,2,3,4,5\}$ with transition matrix
\[
P=
\begin{pmatrix}
1/2 & 1/2 & 0 & 0 & 0\\
1/4 & 0 & 1/4 & 1/2 & 0\\
0 & 0 & 1 & 0 & 0\\
0 & 0 & 0 & 2/3 & 1/3\\
0 & 0 & 0 & 1/2 & 1/2
\end{pmatrix}.
\]

\paragraph{(1) Compute $f_{14}$.}
\textbf{Answer:}
\[
 f_{14}=\frac23.
\]

\textbf{Explanation.} Use first-step expansion. Starting from $1$, the chain either stays at $1$ or moves to $2$:
\[
 f_{14}=p_{11}f_{14}+p_{12}f_{24} = \frac12 f_{14}+\frac12 f_{24}.
\]
Starting from $2$, the chain hits $4$ immediately with probability $1/2$, and if it goes to $1$ then the problem restarts:
\[
 f_{24}=p_{24}+p_{21}f_{14}=\frac12+\frac14 f_{14}.
\]
Substitute into the first equation:
\[
 f_{14}=\frac12 f_{14}+\frac12\left(\frac12+\frac14 f_{14}\right).
\]
Hence
\[
 \frac38 f_{14}=\frac14,
 \qquad
 f_{14}=\frac23.
\]

\paragraph{(2) Find the set of all stationary distributions.}
\textbf{Answer:}
\[
\left\{
\bigl(0,0,1-\lambda,\tfrac35\lambda,\tfrac25\lambda\bigr): \lambda\in[0,1]
\right\}.
\]

\textbf{Explanation.} States $1$ and $2$ are transient, so every stationary distribution must assign them mass $0$. There are then two closed recurrent classes:
\begin{itemize}[leftmargin=2em]
    \item $\{3\}$, where $3$ is absorbing, with stationary distribution $(0,0,1,0,0)$;
    \item $\{4,5\}$, where the restricted transition matrix is
    \[
    \begin{pmatrix}
    2/3 & 1/3\\
    1/2 & 1/2
    \end{pmatrix}.
    \]
\end{itemize}
Let the stationary distribution on $\{4,5\}$ be $(\alpha,\beta)$. Solving
\[
(\alpha,\beta)
\begin{pmatrix}
2/3 & 1/3\\
1/2 & 1/2
\end{pmatrix}
=(\alpha,\beta),
\qquad
\alpha+\beta=1,
\]
gives
\[
\alpha=\frac35,
\qquad
\beta=\frac25.
\]
Therefore every stationary distribution is a convex combination of the two extremal stationary distributions.

\subsection*{Question 3 \hfill [12 points]}
Consider the Markov chain on $S=\{0,1,2,\dots\}$ with transitions
\[
 p_{i,i+1}=\frac{i}{2i+2},
 \qquad
 p_{i,i-1}=\frac{i+2}{2i+2}
 \quad (i\ge 1),
\]
and
\[
 p_{0,0}=\frac12,
 \qquad
 p_{0,1}=\frac12.
\]
Find the stationary distribution $\pi$, and show that
\[
\lim_{n\to\infty} p_{ij}^{(n)}=\pi_j
\qquad \text{for all } i,j.
\]

\textbf{Answer:}
\[
\pi_0=\frac25,
\qquad
\pi_i=\frac{4}{5i(i+2)}, \quad i\ge 1.
\]

\textbf{Explanation.} This is a birth--death chain, so detailed balance is the natural tool. For $i\ge 1$,
\[
\pi_i \cdot \frac{i}{2i+2}
=
\pi_{i+1}\cdot \frac{i+3}{2i+4}.
\]
After simplifying,
\[
 i(i+2)\pi_i=(i+1)(i+3)\pi_{i+1}.
\]
Hence
\[
 \pi_i = \frac{3\pi_1}{i(i+2)}, \qquad i\ge 1.
\]
At state $0$, detailed balance gives
\[
 \pi_0\cdot \frac12 = \pi_1\cdot \frac34,
 \qquad\text{so}\qquad
 \pi_0 = \frac32\pi_1.
\]
Now normalize:
\[
1 = \pi_0 + \sum_{i=1}^{\infty} \pi_i
= \frac32\pi_1 + 3\pi_1\sum_{i=1}^{\infty}\frac{1}{i(i+2)}.
\]
Use
\[
\frac{1}{i(i+2)}=\frac12\left(\frac1i-\frac{1}{i+2}\right),
\]
so
\[
\sum_{i=1}^{\infty}\frac{1}{i(i+2)}=\frac34.
\]
Therefore
\[
1=\frac32\pi_1 + 3\pi_1\cdot \frac34 = \frac{15}{4}\pi_1,
\qquad
\pi_1=\frac{4}{15}.
\]
This yields
\[
\pi_0=\frac25,
\qquad
\pi_i=\frac{4}{5i(i+2)} \quad (i\ge 1).
\]
Finally, the chain is irreducible, aperiodic because $p_{00}>0$, and positive recurrent because a stationary distribution exists. Therefore the Markov chain convergence theorem gives
\[
\lim_{n\to\infty} p_{ij}^{(n)}=\pi_j.
\]

\subsection*{Question 4 \hfill [27 points]}
Let $(B_t)_{t\ge 0}$ be standard Brownian motion.

\paragraph{(1) If $dX_t=-f(X_t)\,dt+dB_t$, find $h$ such that}
\[
M_t:=X_t^2-\int_0^t h(X_s)\,ds
\]
is a martingale, and express $M_t$ as an It\^o integral.

\textbf{Answer:}
\[
 h(x)=1-2xf(x),
 \qquad
 M_t=\int_0^t 2X_s\,dB_s.
\]

\textbf{Explanation.} Apply It\^o's formula to $x\mapsto x^2$:
\[
 d(X_t^2)=2X_t\,dX_t + d\langle X\rangle_t.
\]
Since
\[
 dX_t=-f(X_t)\,dt+dB_t,
 \qquad
 d\langle X\rangle_t=dt,
\]
we get
\[
 d(X_t^2)=\bigl(-2X_t f(X_t)+1\bigr)dt + 2X_t\,dB_t.
\]
Therefore choosing
\[
 h(x)=1-2xf(x)
\]
removes the drift, so
\[
 M_t=X_t^2-\int_0^t (1-2X_s f(X_s))\,ds = \int_0^t 2X_s\,dB_s.
\]

\paragraph{(2) Compute}
\[
\mathbb E\!\left[\max_{0\le t\le 1} B_t \mid B_1=0\right].
\]

\textbf{Answer:}
\[
\mathbb E\!\left[\max_{0\le t\le 1} B_t \mid B_1=0\right]
=
\frac12\sqrt{\frac{\pi}{2}}.
\]

\textbf{Explanation.} Let
\[
M:=\max_{0\le t\le 1} B_t.
\]
By the reflection principle, for $x>0$ and $y<x$,
\[
\mathbb P(M>x, B_1<y)=\mathbb P(B_1>2x-y).
\]
Passing to conditional probabilities gives
\[
\mathbb P(M>x\mid B_1=0)=e^{-2x^2}.
\]
Then use the tail formula for a nonnegative random variable:
\[
\mathbb E[M\mid B_1=0]
=
\int_0^{\infty} \mathbb P(M>x\mid B_1=0)\,dx
=
\int_0^{\infty} e^{-2x^2}\,dx
=
\frac12\sqrt{\frac{\pi}{2}}.
\]

\paragraph{(3) Let $X_t=B_t-t$. Show that $M_t=e^{2X_t}$ is a martingale.}

\textbf{Answer:} $M_t=e^{2X_t}$ is a martingale.

\textbf{Explanation.} Write
\[
 dX_t=dB_t-dt.
\]
Apply It\^o's formula to $f(x)=e^{2x}$, so $f'(x)=2e^{2x}$ and $f''(x)=4e^{2x}$:
\[
 dM_t = 2e^{2X_t}\,dX_t + \frac12\cdot 4e^{2X_t}\,dt.
\]
Substitute $dX_t=dB_t-dt$:
\[
 dM_t = 2e^{2X_t}(dB_t-dt)+2e^{2X_t}dt = 2e^{2X_t}\,dB_t.
\]
The drift vanishes, so $M_t$ is an It\^o integral plus its initial value, hence a martingale.

\paragraph{(4) Define}
\[
\tau:=\inf\{t\ge 0: |X_t|\ge 1\}.
\]
Use part (3) to compute $\mathbb P(X_{\tau}=1)$.

\textbf{Answer:}
\[
\mathbb P(X_{\tau}=1)=\frac{1}{e^2+1}.
\]

\textbf{Explanation.} Since $|X_{t\wedge \tau}|\le 1$, the stopped martingale $e^{2X_{t\wedge\tau}}$ is bounded, so optional stopping applies:
\[
1 = \mathbb E[M_0] = \mathbb E[M_{\tau}] = \mathbb E[e^{2X_{\tau}}].
\]
Now $X_{\tau}\in\{-1,1\}$, so if
\[
 p:=\mathbb P(X_{\tau}=1),
\]
then
\[
1 = e^2 p + e^{-2}(1-p).
\]
Solving gives
\[
 p=\frac{1}{e^2+1}.
\]

\subsection*{Question 5 \hfill [10 points]}
If $(N_1(t))_{t\ge 0}$ and $(N_2(t))_{t\ge 0}$ are independent Poisson processes with intensities $\lambda_1$ and $\lambda_2$, compute
\[
\mathbb P\!
\left(
\text{the last arrival in }[0,t]\text{ is from }N_2
\,
\middle|
\,
N_1(t)+N_2(t)=n
\right).
\]

\textbf{Answer:}
\[
\frac{\lambda_2}{\lambda_1+\lambda_2}.
\]

\textbf{Explanation.} Superpose the two Poisson processes:
\[
N(t):=N_1(t)+N_2(t).
\]
Then $N$ is a Poisson process of rate $\lambda_1+\lambda_2$. Each arrival of the superposed process comes from process $2$ with probability
\[
\frac{\lambda_2}{\lambda_1+\lambda_2},
\]
and from process $1$ with probability
\[
\frac{\lambda_1}{\lambda_1+\lambda_2}.
\]
This label is independent of the arrival time structure. Therefore, even after conditioning on the total number of arrivals being $n$, the last arrival is from $N_2$ with probability
\[
\frac{\lambda_2}{\lambda_1+\lambda_2}.
\]

\subsection*{Question 6 \hfill [17 points]}
Let $(X_k)_{k\ge 0}$ be an irreducible Markov chain on $S=\{0,1,2,\dots\}$ with $|X_{k+1}-X_k|\le 1$ almost surely. Suppose $V:S\to\mathbb R_+$ is nonnegative, strictly increasing, and $V(x)\to\infty$ as $x\to\infty$.

\paragraph{(1) Assume there exists $K<\infty$ such that}
\[
\sum_j p_{ij}V(j)=V(i), \qquad i>K,
\]
and
\[
\sum_j p_{ij}V(j)<\infty, \qquad i=0,1,\dots,K.
\]
Show the chain is recurrent.

\textbf{Answer:} The chain is recurrent.

\textbf{Explanation.} Start from $X_0=K+1$ and define the hitting time
\[
\tau:=\inf\{t>0: X_t\le K\}.
\]
Consider
\[
M_n:=V(X_{n\wedge\tau}).
\]
For states above $K$, the drift condition says $PV=V$, so before hitting $\{0,1,\dots,K\}$ the process has zero drift. Hence $(M_n)$ is a nonnegative martingale. By the martingale convergence theorem, $M_n$ converges almost surely.

If $\tau=\infty$, then the chain never enters $\{0,1,\dots,K\}$. Because the chain moves only one step at a time, it must either keep fluctuating forever above $K$ or drift to infinity. Since $V$ is strictly increasing and unbounded, in either case $V(X_n)$ cannot converge. This contradicts convergence of $M_n$. Therefore $\tau<\infty$ almost surely.

So starting from $K+1$, the chain returns to the lower set almost surely. By irreducibility, every state is hit almost surely from every other state, hence the chain is recurrent.

\paragraph{(2) Assume there exist $K<\infty$ and $\varepsilon>0$ such that}
\[
\sum_j p_{ij}V(j)\le V(i)-\varepsilon, \qquad i>K,
\]
and again $\sum_j p_{ij}V(j)<\infty$ for $i\le K$. Show the chain has a stationary distribution.

\textbf{Answer:} The chain has a stationary distribution.

\textbf{Explanation.} Again let
\[
\tau:=\inf\{t>0: X_t\le K\}
\]
for a chain started from $K+1$. Define
\[
M_n:=V(X_{n\wedge\tau}) + \varepsilon (n\wedge\tau).
\]
The drift condition implies that $(M_n)$ is a supermartingale. Therefore
\[
\mathbb E[M_n]\le \mathbb E[M_0]=V(K+1).
\]
Since $V\ge 0$, this gives
\[
\varepsilon\,\mathbb E[n\wedge\tau]\le V(K+1),
\]
so by letting $n\to\infty$,
\[
\mathbb E[\tau]\le \frac{V(K+1)}{\varepsilon}<\infty.
\]
Hence the return time to the set $\{0,1,\dots,K\}$ has finite expectation. Using the one-step-at-a-time assumption, one gets finite expected return time to $K+1$, so the chain is positive recurrent. An irreducible positive recurrent chain has a stationary distribution.

